{% comment %}
  OPTIMAXXING — Product Page Section
  File: Sections/optimaxxing-product.liquid

  Uses shared header via product.json template.
  Includes Judge.me CSS overrides for dark/neon theme.
{% endcomment %}

{% assign prod = product %}
{% assign first_variant = prod.selected_or_first_available_variant %}

{% comment %} Identify protocol {% endcomment %}
{% assign proto_tag = '' %}
{% assign proto_url = '' %}
{% for tag in prod.tags %}
  {% if tag == 'facemaxx'  %}{% assign proto_tag = 'Facemaxx'  %}{% assign proto_url = '/collections/facemaxx-protocol'  %}{% endif %}
  {% if tag == 'sleepmaxx' %}{% assign proto_tag = 'Sleepmaxx' %}{% assign proto_url = '/collections/sleepmaxx-protocol' %}{% endif %}
  {% if tag == 'gymmaxx'   %}{% assign proto_tag = 'Gymmaxx'   %}{% assign proto_url = '/collections/gymmaxx-protocol'   %}{% endif %}
  {% if tag == 'framemaxx' %}{% assign proto_tag = 'Framemaxx' %}{% assign proto_url = '/collections/framemaxx-protocol' %}{% endif %}
  {% if tag == 'stylemaxx' %}{% assign proto_tag = 'Stylemaxx' %}{% assign proto_url = '/collections/stylemaxx-protocol' %}{% endif %}
  {% if tag == 'mindmaxx'  %}{% assign proto_tag = 'Mindmaxx'  %}{% assign proto_url = '/collections/mindmaxx-protocol'  %}{% endif %}
  {% if tag == 'cleanmaxx' %}{% assign proto_tag = 'Cleanmaxx' %}{% assign proto_url = '/collections/cleanmaxx-protocol' %}{% endif %}
{% endfor %}
{% if proto_tag == '' and prod.collections.size > 0 %}
  {% assign proto_tag = prod.collections.first.title %}
  {% assign proto_url = prod.collections.first.url %}
{% endif %}

{% comment %} Calculate savings {% endcomment %}
{% if prod.compare_at_price > prod.price %}
  {% assign savings = prod.compare_at_price | minus: prod.price | times: 100 | divided_by: prod.compare_at_price %}
{% endif %}

<style>
  /* BREADCRUMB */
  .om-breadcrumb{padding:80px 48px 0;display:flex;align-items:center;gap:10px;}
  .breadcrumb-link{font-family:'Space Mono',monospace;font-size:10px;letter-spacing:1.5px;text-transform:uppercase;color:var(--dim) !important;text-decoration:none !important;transition:color 0.2s;}
  .breadcrumb-link:hover{color:var(--neon) !important;}
  .breadcrumb-sep{font-size:10px;color:var(--dim) !important;}
  .breadcrumb-current{font-family:'Space Mono',monospace;font-size:10px;letter-spacing:1.5px;text-transform:uppercase;color:var(--white) !important;}

  /* PRODUCT LAYOUT */
  .product-wrap{display:grid;grid-template-columns:1fr 1fr;gap:2px;padding:32px 48px 0;}

  /* Images */
  .product-images{position:sticky;top:80px;align-self:start;}
  .main-img-wrap{position:relative;overflow:hidden;aspect-ratio:1;background:var(--gray);margin-bottom:2px;}
  .main-img-wrap img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;display:block;transition:transform 0.4s ease;cursor:zoom-in;}
  .main-img-wrap:hover img{transform:scale(1.04);}
  .img-thumbnails{display:flex;gap:2px;flex-wrap:wrap;}
  .img-thumb{width:80px;height:80px;object-fit:cover;cursor:pointer;border:1px solid transparent;transition:border-color 0.15s;opacity:0.6;}
  .img-thumb.active,.img-thumb:hover{border-color:var(--neon);opacity:1;}

  /* Info */
  .product-info{padding:0 0 0 48px;}
  .product-proto-tag{display:inline-block;margin-bottom:20px;font-family:'Space Mono',monospace;font-size:9px;letter-spacing:2px;text-transform:uppercase;padding:5px 12px;background:var(--neon);color:var(--black) !important;text-decoration:none !important;}
  .product-name{font-family:'Bebas Neue',sans-serif;font-size:clamp(40px,5vw,72px);line-height:0.95;color:var(--white) !important;margin-bottom:24px;}
  .product-price-row{display:flex;align-items:baseline;gap:12px;margin-bottom:8px;}
  .product-price{font-family:'Space Mono',monospace;font-size:28px;font-weight:700;color:var(--neon) !important;}
  .product-compare{font-family:'Space Mono',monospace;font-size:16px;color:var(--dim) !important;text-decoration:line-through;}
  .product-save{font-family:'Space Mono',monospace;font-size:10px;letter-spacing:1px;text-transform:uppercase;color:var(--neon) !important;background:rgba(200,255,0,0.12);padding:3px 8px;}
  .product-trust{display:flex;gap:20px;margin:20px 0 28px;flex-wrap:wrap;}
  .trust-item{display:flex;align-items:center;gap:6px;}
  .trust-icon{color:var(--neon) !important;font-size:12px;}
  .trust-text{font-family:'Space Mono',monospace;font-size:9px;letter-spacing:1px;text-transform:uppercase;color:var(--dim) !important;}

  /* Variants */
  .variant-section{margin-bottom:24px;}
  .variant-label{font-family:'Space Mono',monospace;font-size:10px;letter-spacing:2px;text-transform:uppercase;color:var(--dim) !important;margin-bottom:10px;display:block;}
  .variant-label span{color:var(--white) !important;}
  .variant-btns{display:flex;gap:8px;flex-wrap:wrap;}
  .variant-btn{font-family:'Space Mono',monospace;font-size:10px;letter-spacing:1px;text-transform:uppercase;padding:9px 16px;background:var(--gray);color:var(--dim) !important;border:1px solid var(--border);cursor:pointer;transition:all 0.15s;}
  .variant-btn:hover{border-color:var(--neon);color:var(--white) !important;}
  .variant-btn.active{background:var(--neon);color:var(--black) !important;border-color:var(--neon);}

  /* ATC */
  .atc-section{margin-bottom:24px;}
  .qty-row{display:flex;align-items:center;gap:8px;margin-bottom:14px;}
  .qty-label{font-family:'Space Mono',monospace;font-size:10px;letter-spacing:2px;text-transform:uppercase;color:var(--dim) !important;}
  .qty-ctrl{display:flex;align-items:center;border:1px solid var(--border);}
  .qty-ctrl button{background:var(--gray);border:none;color:var(--white) !important;width:36px;height:36px;cursor:pointer;font-size:16px;display:flex;align-items:center;justify-content:center;transition:background 0.15s;}
  .qty-ctrl button:hover{background:var(--mid);}
  .qty-ctrl input{background:var(--black);border:none;border-left:1px solid var(--border);border-right:1px solid var(--border);color:var(--white) !important;font-family:'Space Mono',monospace;font-size:13px;width:44px;height:36px;text-align:center;outline:none;}
  .atc-btn{display:block;width:100%;padding:16px;background:var(--neon);color:var(--black) !important;font-family:'Space Mono',monospace;font-size:12px;font-weight:700;letter-spacing:3px;text-transform:uppercase;border:none;cursor:pointer;transition:opacity 0.2s;}
  .atc-btn:hover{opacity:0.88;}
  .atc-btn:disabled{opacity:0.4;cursor:not-allowed;}
  .atc-success{display:none;padding:14px;background:rgba(200,255,0,0.1);border:1px solid var(--neon);font-family:'Space Mono',monospace;font-size:10px;letter-spacing:2px;text-transform:uppercase;color:var(--neon) !important;text-align:center;margin-top:12px;}
  .atc-success.show{display:block;}

  /* Tabs */
  .product-tabs{margin-top:40px;border-top:1px solid var(--border);}
  .tab-btns{display:flex;border-bottom:1px solid var(--border);}
  .tab-btn{background:none;border:none;border-bottom:2px solid transparent;padding:16px 20px;font-family:'Space Mono',monospace;font-size:10px;letter-spacing:2px;text-transform:uppercase;color:var(--dim) !important;cursor:pointer;transition:all 0.2s;}
  .tab-btn:hover{color:var(--white) !important;}
  .tab-btn.active{color:var(--neon) !important;border-bottom-color:var(--neon);}
  .tab-panel{display:none;padding:24px 0;}
  .tab-panel.active{display:block;}
  .tab-panel p,.tab-panel li{font-size:14px;color:var(--dim) !important;line-height:1.8;}
  .tab-panel ul{padding-left:20px;}
  .tab-panel li{margin-bottom:8px;}

  /* RELATED */
  .related-section{padding:72px 48px;border-top:1px solid var(--border);}
  .related-heading{font-family:'Space Mono',monospace;font-size:10px;letter-spacing:4px;text-transform:uppercase;color:var(--neon) !important;margin-bottom:8px;display:block;}
  .related-title{font-family:'Bebas Neue',sans-serif;font-size:48px;color:var(--white) !important;margin-bottom:32px;}
  .related-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:2px;}
  .related-card{background:var(--gray);padding:24px;transition:background 0.2s;text-decoration:none !important;}
  .related-card:hover{background:var(--mid);}
  .related-card-img{width:100%;aspect-ratio:1;background:var(--mid);margin-bottom:16px;overflow:hidden;}
  .related-card-img img{width:100%;height:100%;object-fit:cover;}
  .related-card-name{font-family:'Bebas Neue',sans-serif;font-size:20px;color:var(--white) !important;line-height:1.1;margin-bottom:8px;}
  .related-card-price{font-family:'Space Mono',monospace;font-size:14px;color:var(--neon) !important;margin-bottom:12px;}
  .related-link{display:block;width:100%;padding:10px;font-family:'Space Mono',monospace;font-size:9px;letter-spacing:2px;text-transform:uppercase;text-align:center;color:var(--dim) !important;border:1px solid var(--border);transition:all 0.2s;text-decoration:none !important;}
  .related-link:hover{background:var(--neon);border-color:var(--neon);color:var(--black) !important;}

  /* JUDGE.ME DARK THEME OVERRIDES */
  .jdgm-rev-widg{background:var(--black) !important;color:var(--white) !important;border:none !important;font-family:'Inter',sans-serif !important;}
  .jdgm-rev-widg *{color:var(--dim) !important;}
  .jdgm-rev-widg .jdgm-rev__title,.jdgm-rev-widg .jdgm-rev__author{color:var(--white) !important;font-family:'Space Mono',monospace !important;}
  .jdgm-rev-widg .jdgm-rev__body{color:var(--dim) !important;}
  .jdgm-rev-widg .jdgm-star{color:var(--neon) !important;}
  .jdgm-rev-widg .jdgm-rev{border-bottom:1px solid var(--border) !important;padding:24px 0 !important;}
  .jdgm-rev-widg .jdgm-form{background:var(--gray) !important;border:1px solid var(--border) !important;padding:24px !important;}
  .jdgm-rev-widg .jdgm-form input,.jdgm-rev-widg .jdgm-form textarea{background:var(--black) !important;color:var(--white) !important;border:1px solid var(--border) !important;font-family:'Inter',sans-serif !important;}
  .jdgm-rev-widg .jdgm-form__btn{background:var(--neon) !important;color:var(--black) !important;font-family:'Space Mono',monospace !important;letter-spacing:2px !important;text-transform:uppercase !important;border:none !important;}
  .jdgm-rev-widg .jdgm-paginate a{color:var(--neon) !important;border:1px solid var(--border) !important;background:var(--gray) !important;}
  .jdgm-prev-badge .jdgm-star{color:var(--neon) !important;}
  .jdgm-prev-badge__text{color:var(--dim) !important;font-family:'Space Mono',monospace !important;font-size:10px !important;}

  @media(max-width:768px){
    .om-breadcrumb{padding:80px 20px 0;}
    .product-wrap{grid-template-columns:1fr;padding:24px 20px 0;gap:0;}
    .product-images{position:static;margin-bottom:32px;}
    .product-info{padding:0;}
    .related-section{padding:48px 20px;}
  }
</style>

<!-- BREADCRUMB -->
<div class="om-breadcrumb">
  <a href="{{ routes.root_url }}" class="breadcrumb-link">Home</a>
  <span class="breadcrumb-sep">/</span>
  {% if proto_url != '' %}
    <a href="{{ proto_url }}" class="breadcrumb-link">{{ proto_tag }} Protocol</a>
    <span class="breadcrumb-sep">/</span>
  {% endif %}
  <span class="breadcrumb-current">{{ prod.title }}</span>
</div>

<!-- PRODUCT -->
<div class="product-wrap">

  <!-- Images -->
  <div class="product-images">
    <div class="main-img-wrap">
      {% if prod.featured_image %}
        <img id="mainImg" src="{{ prod.featured_image | image_url: width: 800 }}" alt="{{ prod.featured_image.alt | escape }}">
      {% else %}
        <div style="width:100%;aspect-ratio:1;background:var(--mid);display:flex;align-items:center;justify-content:center;">
          <span style="font-family:'Space Mono',monospace;font-size:10px;color:var(--dim);letter-spacing:2px;text-transform:uppercase;">Product Image</span>
        </div>
      {% endif %}
    </div>
    {% if prod.images.size > 1 %}
      <div class="img-thumbnails">
        {% for image in prod.images %}
          <img class="img-thumb{% if forloop.first %} active{% endif %}"
            src="{{ image | image_url: width: 160 }}"
            alt="{{ image.alt | escape }}"
            onclick="omSwapImg(this, '{{ image | image_url: width: 800 }}')"
            width="80" height="80" loading="lazy">
        {% endfor %}
      </div>
    {% endif %}
  </div>

  <!-- Info -->
  <div class="product-info">
    {% if proto_tag != '' %}
      <a href="{{ proto_url }}" class="product-proto-tag">{{ proto_tag }} Protocol</a>
    {% endif %}
    <h1 class="product-name">{{ prod.title | upcase }}</h1>

    <div class="product-price-row">
      <span class="product-price" id="prodPrice">{{ first_variant.price | money }}</span>
      {% if prod.compare_at_price > prod.price %}
        <span class="product-compare">{{ prod.compare_at_price | money }}</span>
        <span class="product-save">{{ savings }}% off</span>
      {% endif %}
    </div>

    <div class="product-trust">
      <div class="trust-item"><span class="trust-icon">&#9733;</span><span class="trust-text">30-Day Guarantee</span></div>
      <div class="trust-item"><span class="trust-icon">&#9650;</span><span class="trust-text">Free Shipping</span></div>
      <div class="trust-item"><span class="trust-icon">&#9632;</span><span class="trust-text">CE Certified</span></div>
    </div>

    <!-- Variants -->
    {% unless prod.has_only_default_variant %}
      {% for option in prod.options_with_values %}
        <div class="variant-section">
          <span class="variant-label">{{ option.name }}: <span id="optVal{{ forloop.index }}">{{ option.selected_value }}</span></span>
          <div class="variant-btns">
            {% for value in option.values %}
              <button class="variant-btn{% if option.selected_value == value %} active{% endif %}" onclick="omSelectOption({{ forloop.index }},'{{ value | escape }}',this)">{{ value }}</button>
            {% endfor %}
          </div>
        </div>
      {% endfor %}
    {% endunless %}

    <!-- Qty + ATC -->
    <div class="atc-section">
      <div class="qty-row">
        <span class="qty-label">Qty</span>
        <div class="qty-ctrl">
          <button type="button" onclick="omQtyChange(-1)">&#8722;</button>
          <input type="number" id="prodQty" value="1" min="1" max="99">
          <button type="button" onclick="omQtyChange(1)">+</button>
        </div>
      </div>
      <button class="atc-btn" id="atcBtn" onclick="omAddToCart()">Add To Protocol &rarr;</button>
      <div class="atc-success" id="atcSuccess">&#10003; Added to your protocol</div>
    </div>

    <!-- Tabs -->
    <div class="product-tabs">
      <div class="tab-btns">
        <button class="tab-btn active" onclick="omShowTab('desc',this)">Description</button>
        <button class="tab-btn" onclick="omShowTab('protocol',this)">How To Use</button>
        <button class="tab-btn" onclick="omShowTab('shipping',this)">Shipping</button>
      </div>
      <div class="tab-panel active" id="desc">
        {% if prod.description != blank %}
          <div style="font-size:14px;color:var(--dim);line-height:1.8;">{{ prod.description }}</div>
        {% else %}
          <p>Full product details coming soon.</p>
        {% endif %}
      </div>
      <div class="tab-panel" id="protocol">
        <ul>
          <li>Use 3-5x per week for best results. Consistency mogs everything.</li>
          <li>Start with 10-minute sessions. Build to 15–20 minutes over 2 weeks.</li>
          <li>Clean face first. Apply serum before for enhanced absorption.</li>
          <li>Evening sessions preferred — red light does not disrupt sleep.</li>
          <li>Visible results typically appear at week 2-3 with consistent use.</li>
        </ul>
      </div>
      <div class="tab-panel" id="shipping">
        <p>Free tracked shipping on all orders. Ships within 1-3 business days. Typical delivery 7-14 business days depending on location.</p>
        <p style="margin-top:16px">30-day protocol guarantee. If the tool does not deliver results within 30 days of consistent use, return it for a full refund. No conditions. No questions.</p>
      </div>
    </div>
  </div>
</div>

<!-- RELATED PRODUCTS -->
{% if prod.collections.size > 0 %}
  {% assign related_col = prod.collections.first %}
  {% if related_col.products.size > 1 %}
    <section class="related-section">
      <span class="related-heading">// Same Protocol</span>
      <h2 class="related-title">COMPLETE YOUR {{ proto_tag | upcase | default: 'PROTOCOL' }}</h2>
      <div class="related-grid">
        {% for rp in related_col.products limit: 5 %}
          {% if rp.handle != prod.handle %}
            <a href="{{ rp.url }}" class="related-card">
              <div class="related-card-img">
                {% if rp.featured_image %}
                  <img src="{{ rp.featured_image | image_url: width: 400 }}" alt="{{ rp.featured_image.alt | escape }}" loading="lazy">
                {% endif %}
              </div>
              <div class="related-card-name">{{ rp.title }}</div>
              <div class="related-card-price">{{ rp.price | money }}</div>
              <span class="related-link">View Product</span>
            </a>
          {% endif %}
        {% endfor %}
      </div>
    </section>
  {% endif %}
{% endif %}

<script>
  var currentVariantId = {{ first_variant.id }};
  var productVariants = {{ prod.variants | json }};

  function omSwapImg(thumb, src){
    document.getElementById('mainImg').src=src;
    document.querySelectorAll('.img-thumb').forEach(function(t){t.classList.remove('active')});
    thumb.classList.add('active');
  }

  function omQtyChange(delta){
    var input=document.getElementById('prodQty');
    var val=parseInt(input.value)+delta;
    input.value=Math.max(1,Math.min(99,val));
  }

  function omSelectOption(optionIndex, value, btn){
    var label=document.getElementById('optVal'+optionIndex);
    if(label) label.textContent=value;
    btn.parentElement.querySelectorAll('.variant-btn').forEach(function(b){b.classList.remove('active')});
    btn.classList.add('active');
    var selectedOptions=[];
    document.querySelectorAll('.variant-section').forEach(function(section){
      var active=section.querySelector('.variant-btn.active');
      if(active) selectedOptions.push(active.textContent.trim());
    });
    var match=productVariants.find(function(v){
      return v.options.every(function(o,i){return o===selectedOptions[i]});
    });
    if(match){
      currentVariantId=match.id;
      document.getElementById('prodPrice').textContent=Shopify.formatMoney ? Shopify.formatMoney(match.price, '{{shop.money_format}}') : ('$'+(match.price/100).toFixed(2));
      document.getElementById('atcBtn').disabled=!match.available;
      document.getElementById('atcBtn').textContent=match.available ? 'Add To Protocol \u2192' : 'Sold Out';
    }
  }

  function omAddToCart(){
    var qty=parseInt(document.getElementById('prodQty').value);
    var btn=document.getElementById('atcBtn');
    btn.disabled=true;btn.textContent='Adding...';
    fetch('/cart/add.js',{
      method:'POST',headers:{'Content-Type':'application/json'},
      body:JSON.stringify({id:currentVariantId,quantity:qty})
    }).then(function(r){return r.json()}).then(function(){
      return fetch('/cart.js');
    }).then(function(r){return r.json()}).then(function(cart){
      var b=document.getElementById('omBadge');
      b.textContent=cart.item_count;
      b.classList.toggle('hidden',cart.item_count===0);
      btn.textContent='Add To Protocol \u2192';btn.disabled=false;
      var success=document.getElementById('atcSuccess');
      success.classList.add('show');
      setTimeout(function(){success.classList.remove('show')},3000);
      // Refresh drawer
      fetch(window.location.pathname+'?sections=optimaxxing-header').then(function(r){return r.json()}).then(function(data){
        var html=data['optimaxxing-header'];
        if(html){
          var doc=new DOMParser().parseFromString(html,'text/html');
          var nb=doc.getElementById('omDrawerBody');
          if(nb) document.getElementById('omDrawerBody').innerHTML=nb.innerHTML;
        }
      });
      if(typeof omOpenCart==='function') omOpenCart();
    }).catch(function(err){
      btn.textContent='Add To Protocol \u2192';btn.disabled=false;
      var success=document.getElementById('atcSuccess');
      success.textContent='Error — please try again';
      success.style.color='#ff4444';success.style.borderColor='#ff4444';success.style.background='rgba(255,68,68,0.08)';
      success.classList.add('show');
      setTimeout(function(){success.classList.remove('show');success.textContent='\u2713 Added to your protocol';success.style.color='';success.style.borderColor='';success.style.background='';},3000);
    });
  }

  function omShowTab(id,btn){
    document.querySelectorAll('.tab-panel').forEach(function(p){p.classList.remove('active')});
    document.querySelectorAll('.tab-btn').forEach(function(b){b.classList.remove('active')});
    document.getElementById(id).classList.add('active');
    btn.classList.add('active');
  }
</script>

{% schema %}
{
  "name": "Optimaxxing Product",
  "settings": [],
  "presets": [{ "name": "Optimaxxing Product" }]
}
{% endschema %}
