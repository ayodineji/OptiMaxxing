{% comment %}
  OPTIMAXXING — Landing Page Section
  File: Sections/optimaxxing-landing.liquid

  Uses shared header via index.json template.
  Protocol tabs pull products from real collections.
{% endcomment %}

{% comment %} Fetch collections for each protocol {% endcomment %}
{% assign face_col   = collections['facemaxx-protocol'] %}
{% assign sleep_col  = collections['sleepmaxx-protocol'] %}
{% assign gym_col    = collections['gymmaxx-protocol'] %}
{% assign frame_col  = collections['framemaxx-protocol'] %}
{% assign style_col  = collections['stylemaxx-protocol'] %}
{% assign mind_col   = collections['mindmaxx-protocol'] %}
{% assign clean_col  = collections['cleanmaxx-protocol'] %}

<style>
  /* HERO */
  .om-hero{min-height:100vh;display:flex;flex-direction:column;justify-content:center;align-items:flex-start;padding:130px 48px 80px;position:relative;overflow:hidden;}
  .om-hero::before{content:'';position:absolute;top:-200px;right:-200px;width:700px;height:700px;background:radial-gradient(circle,rgba(200,255,0,0.055) 0%,transparent 65%);pointer-events:none;}
  .hero-tag{font-family:'Space Mono',monospace;font-size:11px;letter-spacing:4px;color:var(--neon) !important;text-transform:uppercase;margin-bottom:20px;opacity:0;animation:fadeUp 0.6s 0.2s forwards;}
  .hero-title{font-family:'Bebas Neue',sans-serif;font-size:clamp(80px,13vw,160px);line-height:0.9;color:var(--white) !important;margin-bottom:32px;opacity:0;animation:fadeUp 0.7s 0.35s forwards;}
  .hero-title .accent{color:var(--neon) !important;display:block;}
  .hero-sub{font-size:16px;color:var(--dim) !important;max-width:500px;line-height:1.8;margin-bottom:48px;opacity:0;animation:fadeUp 0.7s 0.5s forwards;}
  .hero-btns{display:flex;gap:14px;flex-wrap:wrap;opacity:0;animation:fadeUp 0.7s 0.65s forwards;}
  .btn-primary{background:var(--neon);color:var(--black) !important;padding:15px 40px;font-family:'Space Mono',monospace;font-size:11px;font-weight:700;letter-spacing:3px;text-transform:uppercase;display:inline-block;transition:opacity 0.2s;text-decoration:none !important;}
  .btn-primary:hover{opacity:0.88;}
  .btn-ghost{background:transparent;color:var(--white) !important;border:1px solid #2a2a2a;padding:15px 40px;font-family:'Space Mono',monospace;font-size:11px;letter-spacing:3px;text-transform:uppercase;display:inline-block;transition:border-color 0.2s,color 0.2s;text-decoration:none !important;}
  .btn-ghost:hover{border-color:var(--neon);color:var(--neon) !important;}
  .hero-stats{display:flex;gap:48px;margin-top:80px;padding-top:40px;border-top:1px solid var(--border);width:100%;flex-wrap:wrap;opacity:0;animation:fadeUp 0.7s 0.8s forwards;}
  .stat-item{display:flex;flex-direction:column;gap:4px;}
  .stat-num{font-family:'Bebas Neue',sans-serif;font-size:48px;color:var(--neon) !important;line-height:1;}
  .stat-label{font-size:10px;color:var(--dim) !important;letter-spacing:2px;text-transform:uppercase;}

  /* TICKER */
  .om-ticker{background:var(--neon);padding:12px 0;overflow:hidden;white-space:nowrap;}
  .om-ticker-track{display:inline-block;animation:ticker 35s linear infinite;font-family:'Space Mono',monospace;font-size:11px;font-weight:700;letter-spacing:3px;color:var(--black) !important;text-transform:uppercase;}
  @keyframes ticker{from{transform:translateX(0);}to{transform:translateX(-50%);}}

  /* CALLOUT */
  .om-callout{background:var(--neon);padding:56px 48px;display:flex;align-items:center;justify-content:space-between;gap:32px;flex-wrap:wrap;}
  .callout-text{font-family:'Bebas Neue',sans-serif;font-size:clamp(24px,4vw,48px);color:var(--black) !important;line-height:1.05;max-width:700px;}
  .callout-sub{font-size:12px;color:rgba(0,0,0,0.4) !important;font-family:'Space Mono',monospace;letter-spacing:2px;text-transform:uppercase;max-width:220px;}

  /* PROTOCOL TABS */
  .om-proto-tabs{padding:0 48px;background:var(--gray);border-bottom:1px solid var(--border);display:flex;overflow-x:auto;scrollbar-width:none;}
  .om-proto-tabs::-webkit-scrollbar{display:none;}
  .proto-tab{padding:18px 24px;font-family:'Space Mono',monospace;font-size:10px;letter-spacing:2px;text-transform:uppercase;color:var(--dim) !important;cursor:pointer;white-space:nowrap;background:none;border:none;border-bottom:2px solid transparent;transition:color 0.2s,border-color 0.2s;flex-shrink:0;}
  .proto-tab.active,.proto-tab:hover{color:var(--neon) !important;border-bottom-color:var(--neon);}
  .proto-tab.clean.active,.proto-tab.clean:hover{color:#00CFFF !important;border-bottom-color:#00CFFF;}

  /* PRODUCTS */
  .om-products{padding:72px 48px;}
  .section-tag{font-family:'Space Mono',monospace;font-size:10px;letter-spacing:4px;color:var(--neon) !important;text-transform:uppercase;margin-bottom:12px;display:block;}
  .section-heading{font-family:'Bebas Neue',sans-serif;font-size:clamp(36px,5.5vw,72px);line-height:1;color:var(--white) !important;margin-bottom:14px;}
  .section-body{font-size:14px;color:var(--dim) !important;max-width:580px;line-height:1.75;margin-bottom:24px;}
  .view-all-link{display:inline-block;margin-bottom:36px;font-family:'Space Mono',monospace;font-size:10px;letter-spacing:2px;text-transform:uppercase;color:var(--neon) !important;border-bottom:1px solid var(--neon);padding-bottom:2px;transition:opacity 0.2s;text-decoration:none !important;}
  .view-all-link:hover{opacity:0.7;}
  .proto-panel{display:none;}
  .proto-panel.active{display:block;}
  .product-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:2px;}

  /* CARDS */
  .product-card{background:var(--gray);padding:28px 24px;display:flex;flex-direction:column;transition:background 0.2s;text-decoration:none !important;}
  .product-card:hover{background:var(--mid);}
  .product-card.hero-card{background:var(--neon) !important;}
  .product-card.hero-card .card-badge{background:var(--black);color:var(--neon) !important;}
  .product-card.hero-card .card-name{color:var(--black) !important;}
  .product-card.hero-card .card-desc{color:rgba(0,0,0,0.5) !important;}
  .product-card.hero-card .card-price{color:var(--black) !important;}
  .product-card.hero-card .card-link{color:var(--black) !important;border-color:var(--black);}
  .product-card.hero-card .card-link:hover{background:var(--black);color:var(--neon) !important;}
  .card-badge{display:inline-block;align-self:flex-start;margin-bottom:18px;font-family:'Space Mono',monospace;font-size:9px;letter-spacing:2px;padding:4px 10px;background:var(--mid);color:var(--neon) !important;text-transform:uppercase;}
  .card-img-wrap{width:100%;aspect-ratio:1;overflow:hidden;margin-bottom:18px;background:var(--mid);}
  .card-img-wrap img{width:100%;height:100%;object-fit:cover;display:block;}
  .card-img{width:100%;aspect-ratio:1 !important;object-fit:cover !important;margin-bottom:18px;background:var(--mid);display:block;}
  .card-img-placeholder{width:100%;aspect-ratio:1;background:var(--mid);margin-bottom:18px;display:flex;align-items:center;justify-content:center;}
  .card-img-placeholder span{font-family:'Space Mono',monospace;font-size:9px;color:var(--dim) !important;letter-spacing:2px;text-transform:uppercase;}
  .card-name{font-family:'Bebas Neue',sans-serif;font-size:24px;line-height:1.1;color:var(--white) !important;margin-bottom:10px;flex:1;}
  .card-desc{font-size:12px;color:var(--dim) !important;line-height:1.7;margin-bottom:18px;}
  .card-price{font-family:'Space Mono',monospace;font-size:18px;font-weight:700;color:var(--neon) !important;}
  .card-link{display:block;width:100%;margin-top:14px;padding:11px;background:transparent;border:1px solid #2a2a2a;font-family:'Space Mono',monospace;font-size:10px;letter-spacing:2px;text-transform:uppercase;text-align:center;color:var(--white) !important;transition:background 0.2s,border-color 0.2s,color 0.2s;text-decoration:none !important;}
  .product-card:not(.hero-card) .card-link:hover{background:var(--neon);border-color:var(--neon);color:var(--black) !important;}

  /* HOW */
  .om-how{padding:96px 48px;background:#060606;}
  .steps-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:48px;margin-top:56px;}
  .step-num{font-family:'Bebas Neue',sans-serif;font-size:80px;color:#181818;line-height:1;margin-bottom:14px;}
  .step-title{font-family:'Bebas Neue',sans-serif;font-size:24px;color:var(--white) !important;margin-bottom:10px;}
  .step-desc{font-size:13px;color:var(--dim) !important;line-height:1.75;}

  /* PROOF */
  .om-proof{padding:96px 48px;}
  .proof-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:2px;margin-top:56px;}
  .proof-card{background:var(--gray);padding:28px 24px;}
  .proof-stars{color:var(--neon) !important;font-size:13px;letter-spacing:3px;margin-bottom:14px;}
  .proof-quote{font-size:14px;line-height:1.75;color:var(--white) !important;margin-bottom:18px;font-style:italic;}
  .proof-who{font-family:'Space Mono',monospace;font-size:9px;color:var(--neon) !important;letter-spacing:2px;text-transform:uppercase;}

  /* PAGES NAV STRIP */
  .pages-strip{background:#0a0a0a;border-top:1px solid var(--border);border-bottom:1px solid var(--border);padding:32px 48px;display:flex;gap:2px;flex-wrap:wrap;}
  .pages-strip a{flex:1;min-width:200px;padding:28px 24px;display:flex;flex-direction:column;gap:8px;text-decoration:none !important;transition:background 0.2s;}
  .strip-dark{background:var(--gray);}
  .strip-dark:hover{background:var(--mid);}
  .strip-neon{background:var(--neon);}
  .strip-tag{font-family:'Space Mono',monospace;font-size:9px;letter-spacing:3px;text-transform:uppercase;}
  .strip-title{font-family:'Bebas Neue',sans-serif;font-size:32px;line-height:1;}
  .strip-desc{font-size:12px;}

  @keyframes fadeUp{from{opacity:0;transform:translateY(20px);}to{opacity:1;transform:translateY(0);}}

  @media(max-width:768px){
    .om-hero{padding:100px 20px 56px;}
    .hero-stats{gap:20px;margin-top:48px;}
    .stat-num{font-size:40px;}
    .om-callout{flex-direction:column;padding:40px 20px;}
    .om-proto-tabs{padding:0 16px;}
    .om-products,.om-how,.om-proof{padding:56px 20px;}
    .product-grid{grid-template-columns:1fr;}
    .steps-grid{gap:32px;}
    .pages-strip{padding:20px;flex-direction:column;}
  }
</style>

