<section class="om-products">

  {% comment %} ── MACRO: Render a protocol panel ── {% endcomment %}
  {% comment %} We render each protocol manually because each has unique copy {% endcomment %}

  <!-- FACEMAXX -->
  <div class="proto-panel active" id="facemaxx">
    <span class="section-tag">// Protocol 01</span>
    <h2 class="section-heading">FACEMAXX</h2>
    <p class="section-body">Your face is a variable. These are the clinical-grade tools to adjust it. LED therapy, microcurrent, cryotherapy — delivered to your door.</p>
    <a href="{{ face_col.url }}" class="view-all-link">View Full Facemaxx Collection &rarr;</a>
    <div class="product-grid">
      {% for product in face_col.products limit: 4 %}
        <a href="{{ product.url }}" class="product-card{% if forloop.first %} hero-card{% endif %}">
          <span class="card-badge">{% if forloop.first %}&#9733; Hero Product{% else %}Protocol Tool{% endif %}</span>
          {% if product.featured_image %}
            <img class="card-img" src="{{ product.featured_image | image_url: width: 500 }}" alt="{{ product.featured_image.alt | escape }}" loading="lazy">
          {% else %}
            <div class="card-img-placeholder"><span>Product Image</span></div>
          {% endif %}
          <h3 class="card-name">{{ product.title }}</h3>
          {% if product.metafields.custom.short_description != blank %}
            <p class="card-desc">{{ product.metafields.custom.short_description }}</p>
          {% elsif product.description != blank %}
            <p class="card-desc">{{ product.description | strip_html | truncate: 120 }}</p>
          {% endif %}
          <p class="card-price">{{ product.price | money }}</p>
          <span class="card-link">View Product</span>
        </a>
      {% endfor %}
      {% if face_col.products_count == 0 %}
        <div class="product-card"><div class="card-img-placeholder"><span>Coming Soon</span></div><h3 class="card-name">Products being stocked</h3><p class="card-desc">Check back soon.</p></div>
      {% endif %}
    </div>
  </div>

