{% comment %}
  OPTIMAXXING — Homepage Section
  File: Sections/optimaxxing-landing.liquid
  templates/index.json points to this as the homepage.

  Collection handles (must match exactly):
  facemaxx-protocol | sleepmaxx-protocol | gymmaxx-protocol
  framemaxx-protocol | stylemaxx-protocol | mindmaxx-protocol | cleanmaxx-protocol

  Product order: Admin > Products > Collections > drag.
  First product in each collection = neon hero card.
{% endcomment %}

{% assign col_facemaxx  = collections['facemaxx-protocol']  %}
{% assign col_sleepmaxx = collections['sleepmaxx-protocol'] %}
{% assign col_gymmaxx   = collections['gymmaxx-protocol']   %}
{% assign col_framemaxx = collections['framemaxx-protocol'] %}
{% assign col_stylemaxx = collections['stylemaxx-protocol'] %}
{% assign col_mindmaxx  = collections['mindmaxx-protocol']  %}
{% assign col_cleanmaxx = collections['cleanmaxx-protocol'] %}
{% assign cart_count = cart.item_count %}

<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Space+Mono:wght@400;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">

<style>
  :root {
    --black:  #050505;
    --neon:   #C8FF00;
    --white:  #F5F5F5;
    --gray:   #141414;
    --mid:    #202020;
    --dim:    #888;
    --border: #1e1e1e;
  }

  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; }

  body, .shopify-section, main, #MainContent,
  .template-index { background: var(--black) !important; color: var(--white) !important; }
  body { font-family: 'Inter', sans-serif; overflow-x: hidden; }

  .section-header, header-drawer, .header-wrapper,
  .header, #shopify-section-header,
  .announcement-bar { display: none !important; }

  h1, h2, h3, h4, h5, h6 { color: var(--white) !important; }
  p, li, span, label { color: var(--dim) !important; }
  a { color: inherit; text-decoration: none; }

  /* NAV */
  .om-nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
    display: flex; justify-content: space-between; align-items: center;
    padding: 0 48px; height: 64px;
    background: rgba(5,5,5,0.96); backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--border);
  }
  .om-logo {
    font-family: 'Bebas Neue', sans-serif; font-size: 22px;
    letter-spacing: 4px; color: var(--neon) !important;
    text-decoration: none !important; flex-shrink: 0; line-height: 1;
  }
  .om-logo .logo-rest { color: var(--white) !important; }
  .om-nav-center { position: relative; display: flex; align-items: center; }
  .om-protocols-btn {
    background: none; border: none; cursor: pointer;
    font-family: 'Space Mono', monospace; font-size: 10px;
    letter-spacing: 2px; text-transform: uppercase;
    color: var(--dim) !important; padding: 0 16px; height: 64px;
    transition: color 0.2s; display: flex; align-items: center; gap: 8px;
  }
  .om-protocols-btn:hover, .om-protocols-btn.open { color: var(--neon) !important; }
  .om-chevron { transition: transform 0.2s; font-size: 8px; line-height: 1; display: inline-block; }
  .om-protocols-btn.open .om-chevron { transform: rotate(180deg); }
  .om-dropdown {
    position: absolute; top: 64px; left: 50%; transform: translateX(-50%);
    background: #080808; border: 1px solid var(--border);
    border-top: 2px solid var(--neon);
    display: none; min-width: 220px; z-index: 1001;
    box-shadow: 0 16px 48px rgba(0,0,0,0.6);
  }
  .om-dropdown.open { display: block; }
  .om-dropdown a {
    display: flex; align-items: center; gap: 12px;
    padding: 14px 20px; text-decoration: none !important;
    font-family: 'Space Mono', monospace; font-size: 10px;
    letter-spacing: 2px; text-transform: uppercase;
    color: var(--dim) !important; border-bottom: 1px solid var(--border);
    transition: background 0.15s, color 0.15s;
  }
  .om-dropdown a:last-child { border-bottom: none; }
  .om-dropdown a:hover { background: var(--gray); color: var(--neon) !important; }
  .om-dropdown .pnum { color: var(--neon) !important; font-size: 9px; opacity: 0.6; }
  .om-nav-right { display: flex; align-items: center; gap: 14px; }
  .om-cart-btn {
    position: relative; background: none; border: none; cursor: pointer;
    color: var(--white) !important; padding: 8px;
    display: flex; align-items: center; transition: color 0.2s;
  }
  .om-cart-btn:hover { color: var(--neon) !important; }
  .om-cart-btn svg { width: 22px; height: 22px; stroke: currentColor; }
  .om-badge {
    position: absolute; top: 1px; right: 1px;
    background: var(--neon); color: var(--black) !important;
    font-family: 'Space Mono', monospace; font-size: 8px; font-weight: 700;
    width: 15px; height: 15px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
  }
  .om-badge.hidden { display: none; }
  .om-nav-cta {
    background: var(--neon); color: var(--black) !important;
    padding: 10px 20px; font-family: 'Space Mono', monospace;
    font-size: 10px; font-weight: 700; letter-spacing: 2px;
    text-transform: uppercase; text-decoration: none !important;
    transition: opacity 0.2s; white-space: nowrap;
  }
  .om-nav-cta:hover { opacity: 0.85; }
  .om-hamburger {
    display: none; background: none; border: none; cursor: pointer;
    flex-direction: column; gap: 5px; padding: 8px;
  }
  .om-hamburger span { display: block; width: 22px; height: 1.5px; background: var(--white); transition: all 0.25s; }
  .om-hamburger.open span:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
  .om-hamburger.open span:nth-child(2) { opacity: 0; }
  .om-hamburger.open span:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }
  .om-mobile-menu {
    display: none; position: fixed; top: 64px; left: 0; right: 0;
    background: #080808; border-bottom: 1px solid var(--border); z-index: 999; padding: 8px 0;
  }
  .om-mobile-menu.open { display: block; }
  .om-mobile-menu a {
    display: flex; align-items: center; gap: 12px;
    padding: 14px 20px; text-decoration: none !important;
    font-family: 'Space Mono', monospace; font-size: 10px;
    letter-spacing: 2px; text-transform: uppercase;
    color: var(--dim) !important; border-bottom: 1px solid var(--border);
  }
  .om-mobile-menu a:last-child { border-bottom: none; }
  .om-mobile-menu a:hover { color: var(--neon) !important; }

  /* CART DRAWER */
  .om-overlay {
    position: fixed; inset: 0; background: rgba(0,0,0,0.75);
    z-index: 1999; opacity: 0; pointer-events: none; transition: opacity 0.3s;
  }
  .om-overlay.open { opacity: 1; pointer-events: all; }
  .om-drawer {
    position: fixed; top: 0; right: 0; width: 400px; max-width: 100vw;
    height: 100vh; background: #080808; border-left: 1px solid var(--border);
    z-index: 2000; display: flex; flex-direction: column;
    transform: translateX(100%); transition: transform 0.35s cubic-bezier(0.4,0,0.2,1);
  }
  .om-drawer.open { transform: translateX(0); }
  .om-drawer-head {
    display: flex; justify-content: space-between; align-items: center;
    padding: 20px 24px; border-bottom: 1px solid var(--border); flex-shrink: 0;
  }
  .om-drawer-head h2 { font-family: 'Bebas Neue', sans-serif; font-size: 24px; color: var(--white) !important; letter-spacing: 2px; }
  .om-drawer-head h2 span { color: var(--neon) !important; }
  .om-drawer-x { background: none; border: none; cursor: pointer; color: var(--dim) !important; font-size: 22px; padding: 4px; transition: color 0.2s; }
  .om-drawer-x:hover { color: var(--white) !important; }
  .om-drawer-body { flex: 1; overflow-y: auto; padding: 16px 24px; }
  .om-empty-cart { height: 100%; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 14px; text-align: center; }
  .om-empty-cart p { font-family: 'Space Mono', monospace; font-size: 10px; letter-spacing: 2px; text-transform: uppercase; color: var(--dim) !important; }
  .om-empty-cart a { font-family: 'Space Mono', monospace; font-size: 10px; color: var(--neon) !important; border-bottom: 1px solid var(--neon); padding-bottom: 2px; }
  .om-cart-item { display: flex; gap: 14px; padding: 16px 0; border-bottom: 1px solid var(--border); }
  .om-cart-item img { width: 64px; height: 64px; object-fit: cover; flex-shrink: 0; }
  .om-item-info { flex: 1; }
  .om-item-name { font-family: 'Bebas Neue', sans-serif; font-size: 17px; color: var(--white) !important; line-height: 1.1; margin-bottom: 4px; }
  .om-item-price { font-family: 'Space Mono', monospace; font-size: 12px; color: var(--neon) !important; margin-bottom: 10px; }
  .om-qty-row { display: flex; align-items: center; gap: 10px; }
  .om-qty-btn { background: var(--mid); border: none; color: var(--white) !important; width: 24px; height: 24px; cursor: pointer; font-size: 14px; display: flex; align-items: center; justify-content: center; transition: background 0.15s; }
  .om-qty-btn:hover { background: var(--neon); color: var(--black) !important; }
  .om-qty-val { font-family: 'Space Mono', monospace; font-size: 12px; color: var(--white) !important; min-width: 20px; text-align: center; }
  .om-item-remove { background: none; border: none; cursor: pointer; font-family: 'Space Mono', monospace; font-size: 9px; letter-spacing: 1px; text-transform: uppercase; color: var(--dim) !important; margin-top: 8px; display: block; }
  .om-item-remove:hover { color: var(--white) !important; }
  .om-drawer-foot { padding: 20px 24px; border-top: 1px solid var(--border); flex-shrink: 0; }
  .om-subtotal-row { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 16px; }
  .om-subtotal-label { font-family: 'Space Mono', monospace; font-size: 10px; letter-spacing: 2px; text-transform: uppercase; color: var(--dim) !important; }
  .om-subtotal-price { font-family: 'Space Mono', monospace; font-size: 20px; font-weight: 700; color: var(--neon) !important; }
  .om-checkout { display: block; width: 100%; padding: 15px; text-align: center; background: var(--neon); color: var(--black) !important; font-family: 'Space Mono', monospace; font-size: 11px; font-weight: 700; letter-spacing: 3px; text-transform: uppercase; text-decoration: none !important; transition: opacity 0.2s; }
  .om-checkout:hover { opacity: 0.88; }

  /* HERO */
  .om-hero {
    min-height: 100vh; display: flex; flex-direction: column;
    justify-content: center; align-items: flex-start;
    padding: 130px 48px 80px; position: relative; overflow: hidden;
  }
  .om-hero::before {
    content: ''; position: absolute; top: -200px; right: -200px;
    width: 700px; height: 700px;
    background: radial-gradient(circle, rgba(200,255,0,0.055) 0%, transparent 65%);
    pointer-events: none;
  }
  .hero-tag { font-family: 'Space Mono', monospace; font-size: 11px; letter-spacing: 4px; color: var(--neon) !important; text-transform: uppercase; margin-bottom: 20px; opacity: 0; animation: fadeUp 0.6s 0.2s forwards; }
  .hero-title { font-family: 'Bebas Neue', sans-serif; font-size: clamp(80px, 13vw, 160px); line-height: 0.9; color: var(--white) !important; margin-bottom: 32px; opacity: 0; animation: fadeUp 0.7s 0.35s forwards; }
  .hero-title .accent { color: var(--neon) !important; display: block; }
  .hero-sub { font-size: 16px; color: var(--dim) !important; max-width: 500px; line-height: 1.8; margin-bottom: 48px; opacity: 0; animation: fadeUp 0.7s 0.5s forwards; }
  .hero-btns { display: flex; gap: 14px; flex-wrap: wrap; opacity: 0; animation: fadeUp 0.7s 0.65s forwards; }
  .btn-primary { background: var(--neon); color: var(--black) !important; padding: 15px 40px; font-family: 'Space Mono', monospace; font-size: 11px; font-weight: 700; letter-spacing: 3px; text-transform: uppercase; text-decoration: none !important; transition: transform 0.2s, opacity 0.2s; display: inline-block; }
  .btn-primary:hover { transform: translateY(-2px); opacity: 0.9; }
  .btn-ghost { background: transparent; color: var(--white) !important; border: 1px solid #2a2a2a; padding: 15px 40px; font-family: 'Space Mono', monospace; font-size: 11px; letter-spacing: 3px; text-transform: uppercase; text-decoration: none !important; display: inline-block; transition: border-color 0.2s, color 0.2s; }
  .btn-ghost:hover { border-color: var(--neon); color: var(--neon) !important; }
  .hero-stats { display: flex; gap: 48px; margin-top: 80px; padding-top: 40px; border-top: 1px solid var(--border); width: 100%; flex-wrap: wrap; opacity: 0; animation: fadeUp 0.7s 0.8s forwards; }
  .stat-item { display: flex; flex-direction: column; gap: 4px; }
  .stat-num { font-family: 'Bebas Neue', sans-serif; font-size: 48px; color: var(--neon) !important; line-height: 1; }
  .stat-label { font-size: 10px; color: var(--dim) !important; letter-spacing: 2px; text-transform: uppercase; }

  /* TICKER */
  .om-ticker { background: var(--neon); padding: 12px 0; overflow: hidden; white-space: nowrap; }
  .om-ticker-track { display: inline-block; animation: ticker 30s linear infinite; font-family: 'Space Mono', monospace; font-size: 11px; font-weight: 700; letter-spacing: 3px; color: var(--black) !important; text-transform: uppercase; }
  @keyframes ticker { from { transform: translateX(0); } to { transform: translateX(-50%); } }

  /* CALLOUT */
  .om-callout { background: var(--neon); padding: 56px 48px; display: flex; align-items: center; justify-content: space-between; gap: 32px; flex-wrap: wrap; }
  .callout-text { font-family: 'Bebas Neue', sans-serif; font-size: clamp(24px, 4vw, 48px); color: var(--black) !important; line-height: 1.05; max-width: 700px; }
  .callout-sub { font-size: 12px; color: rgba(0,0,0,0.4) !important; font-family: 'Space Mono', monospace; letter-spacing: 2px; text-transform: uppercase; max-width: 220px; }

  /* PROTOCOL TABS */
  .om-proto-tabs { padding: 0 48px; background: var(--gray); border-bottom: 1px solid var(--border); display: flex; overflow-x: auto; scrollbar-width: none; }
  .om-proto-tabs::-webkit-scrollbar { display: none; }
  .proto-tab { padding: 18px 24px; font-family: 'Space Mono', monospace; font-size: 10px; letter-spacing: 2px; text-transform: uppercase; color: var(--dim) !important; cursor: pointer; white-space: nowrap; background: none; border: none; border-bottom: 2px solid transparent; transition: color 0.2s, border-color 0.2s; flex-shrink: 0; }
  .proto-tab.active, .proto-tab:hover { color: var(--neon) !important; border-bottom-color: var(--neon); }

  /* PRODUCTS */
  .om-products { padding: 72px 48px; }
  .section-tag { font-family: 'Space Mono', monospace; font-size: 10px; letter-spacing: 4px; color: var(--neon) !important; text-transform: uppercase; margin-bottom: 12px; display: block; }
  .section-heading { font-family: 'Bebas Neue', sans-serif; font-size: clamp(36px, 5.5vw, 72px); line-height: 1; color: var(--white) !important; margin-bottom: 14px; }
  .section-body { font-size: 14px; color: var(--dim) !important; max-width: 580px; line-height: 1.75; margin-bottom: 24px; }
  .view-all-link { display: inline-block; margin-bottom: 36px; font-family: 'Space Mono', monospace; font-size: 10px; letter-spacing: 2px; text-transform: uppercase; color: var(--neon) !important; text-decoration: none !important; border-bottom: 1px solid var(--neon); padding-bottom: 2px; transition: opacity 0.2s; }
  .view-all-link:hover { opacity: 0.7; }
  .proto-panel { display: none; }
  .proto-panel.active { display: block; }
  .product-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 2px; }

  /* Cards */
  .product-card { background: var(--gray); padding: 28px 24px; display: flex; flex-direction: column; transition: background 0.2s; }
  .product-card:hover { background: var(--mid); }
  .product-card.hero-card { background: var(--neon) !important; }
  .product-card.hero-card .card-badge  { background: var(--black); color: var(--neon) !important; }
  .product-card.hero-card .card-name   { color: var(--black) !important; }
  .product-card.hero-card .card-desc   { color: rgba(0,0,0,0.5) !important; }
  .product-card.hero-card .card-price  { color: var(--black) !important; }
  .product-card.hero-card .card-link   { color: var(--black) !important; border-color: var(--black) !important; }
  .product-card.hero-card .card-link:hover { background: var(--black) !important; color: var(--neon) !important; }
  .card-badge { display: inline-block; align-self: flex-start; margin-bottom: 18px; font-family: 'Space Mono', monospace; font-size: 9px; letter-spacing: 2px; padding: 4px 10px; background: var(--mid); color: var(--neon) !important; text-transform: uppercase; }
  .card-img { width: 100%; aspect-ratio: 1; object-fit: cover; margin-bottom: 18px; display: block; }
  .card-img-placeholder { width: 100%; aspect-ratio: 1; background: var(--mid); margin-bottom: 18px; display: flex; align-items: center; justify-content: center; }
  .card-img-placeholder span { font-family: 'Space Mono', monospace; font-size: 9px; color: var(--dim) !important; letter-spacing: 2px; text-transform: uppercase; }
  .card-name  { font-family: 'Bebas Neue', sans-serif; font-size: 24px; line-height: 1.1; color: var(--white) !important; margin-bottom: 10px; flex: 1; }
  .card-desc  { font-size: 12px; color: var(--dim) !important; line-height: 1.7; margin-bottom: 18px; }
  .card-price { font-family: 'Space Mono', monospace; font-size: 18px; font-weight: 700; color: var(--neon) !important; }
  .card-link { display: block; width: 100%; margin-top: 14px; padding: 11px; background: transparent; border: 1px solid #2a2a2a; font-family: 'Space Mono', monospace; font-size: 10px; letter-spacing: 2px; text-transform: uppercase; text-decoration: none !important; text-align: center; color: var(--white) !important; transition: background 0.2s, border-color 0.2s, color 0.2s; }
  .product-card:not(.hero-card) .card-link:hover { background: var(--neon); border-color: var(--neon); color: var(--black) !important; }
  .empty-col { padding: 56px; background: var(--gray); text-align: center; }
  .empty-col p { font-family: 'Space Mono', monospace; font-size: 10px; color: var(--dim) !important; letter-spacing: 2px; text-transform: uppercase; }

  /* HOW */
  .om-how { padding: 96px 48px; background: #060606 !important; }
  .steps-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 48px; margin-top: 56px; }
  .step-num { font-family: 'Bebas Neue', sans-serif; font-size: 80px; color: #181818 !important; line-height: 1; margin-bottom: 14px; }
  .step-title { font-family: 'Bebas Neue', sans-serif; font-size: 24px; color: var(--white) !important; margin-bottom: 10px; }
  .step-desc { font-size: 13px; color: var(--dim) !important; line-height: 1.75; }

  /* PROOF */
  .om-proof { padding: 96px 48px; }
  .proof-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 2px; margin-top: 56px; }
  .proof-card { background: var(--gray); padding: 28px 24px; }
  .proof-stars { color: var(--neon) !important; font-size: 13px; letter-spacing: 3px; margin-bottom: 14px; }
  .proof-quote { font-size: 14px; line-height: 1.75; color: var(--white) !important; margin-bottom: 18px; font-style: italic; }
  .proof-who { font-family: 'Space Mono', monospace; font-size: 9px; color: var(--neon) !important; letter-spacing: 2px; text-transform: uppercase; }

  /* FOOTER */
  .om-footer { padding: 40px 48px; border-top: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 16px; }
  .footer-brand { font-family: 'Bebas Neue', sans-serif; font-size: 20px; letter-spacing: 4px; color: var(--neon) !important; text-decoration: none !important; }
  .footer-links { display: flex; gap: 24px; flex-wrap: wrap; }
  .footer-links a { font-family: 'Space Mono', monospace; font-size: 10px; letter-spacing: 1.5px; text-transform: uppercase; color: var(--dim) !important; text-decoration: none !important; transition: color 0.2s; }
  .footer-links a:hover { color: var(--neon) !important; }
  .footer-copy { font-size: 11px; color: var(--dim) !important; }

  @keyframes fadeUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }

  /* MOBILE */
  @media (max-width: 768px) {
    .om-nav { padding: 0 16px; }
    .om-logo { font-size: 17px; letter-spacing: 3px; }
    .om-nav-center { display: none; }
    .om-nav-cta { display: none; }
    .om-hamburger { display: flex; }

    .om-hero { padding: 100px 20px 56px; }
    .hero-stats { gap: 20px; margin-top: 48px; }
    .stat-num { font-size: 40px; }

    .om-callout { flex-direction: column; padding: 40px 20px; }
    .callout-sub { max-width: 100%; }
    .om-proto-tabs { padding: 0 16px; }
    .om-products, .om-how, .om-proof { padding: 56px 20px; }
    .product-grid { grid-template-columns: 1fr; }
    .steps-grid { gap: 32px; }
    .om-footer { flex-direction: column; padding: 28px 20px; text-align: center; }
    .footer-links { justify-content: center; }
    .om-drawer { width: 100vw; }
  }
</style>

<!-- OVERLAY -->
<div class="om-overlay" id="omOverlay" onclick="omCloseCart()"></div>

<!-- CART DRAWER -->
<div class="om-drawer" id="omDrawer">
  <div class="om-drawer-head">
    <h2>YOUR <span>PROTOCOL</span></h2>
    <button class="om-drawer-x" onclick="omCloseCart()">&times;</button>
  </div>
  <div class="om-drawer-body" id="omDrawerBody">
    {% if cart.item_count == 0 %}
      <div class="om-empty-cart">
        <p>Your protocol is empty.</p>
        <a href="#protocols" onclick="omCloseCart()">Start building &rarr;</a>
      </div>
    {% else %}
      {% for item in cart.items %}
        <div class="om-cart-item" data-key="{{ item.key }}">
          {% if item.image %}
            <img src="{{ item.image | image_url: width: 128 }}" alt="{{ item.title | escape }}" width="64" height="64">
          {% endif %}
          <div class="om-item-info">
            <p class="om-item-name">{{ item.product.title }}</p>
            <p class="om-item-price">{{ item.final_price | money }}</p>
            <div class="om-qty-row">
              <button class="om-qty-btn" onclick="omUpdateQty('{{ item.key }}', {{ item.quantity | minus: 1 }})">&#8722;</button>
              <span class="om-qty-val">{{ item.quantity }}</span>
              <button class="om-qty-btn" onclick="omUpdateQty('{{ item.key }}', {{ item.quantity | plus: 1 }})">+</button>
            </div>
