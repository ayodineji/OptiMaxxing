        <a href="{{ product.url }}" class="product-card{% if forloop.first %} hero-card{% endif %}"{% if forloop.first %} style="background:#00CFFF !important"{% endif %}>
          <span class="card-badge"{% if forloop.first %} style="background:var(--black);color:#00CFFF !important"{% else %} style="color:#00CFFF !important"{% endif %}>{% if forloop.first %}&#9733; Hero Product{% else %}Protocol Tool{% endif %}</span>
          {% if product.featured_image %}
            <img class="card-img" src="{{ product.featured_image | image_url: width: 500 }}" alt="{{ product.featured_image.alt | escape }}" loading="lazy">
          {% else %}
            <div class="card-img-placeholder"><span>Product Image</span></div>
          {% endif %}
          <h3 class="card-name"{% if forloop.first %} style="color:var(--black) !important"{% endif %}>{{ product.title }}</h3>
          {% if product.metafields.custom.short_description != blank %}
            <p class="card-desc"{% if forloop.first %} style="color:rgba(0,0,0,0.5) !important"{% endif %}>{{ product.metafields.custom.short_description }}</p>
          {% elsif product.description != blank %}
            <p class="card-desc"{% if forloop.first %} style="color:rgba(0,0,0,0.5) !important"{% endif %}>{{ product.description | strip_html | truncate: 120 }}</p>
          {% endif %}
          <p class="card-price"{% if forloop.first %} style="color:var(--black) !important"{% else %} style="color:#00CFFF !important"{% endif %}>{{ product.price | money }}</p>
          <span class="card-link"{% if forloop.first %} style="color:var(--black) !important;border-color:var(--black)"{% endif %}>View Product</span>
        </a>
      {% endfor %}
      {% if clean_col.products_count == 0 %}
        <div class="product-card"><div class="card-img-placeholder"><span>Coming Soon</span></div><h3 class="card-name">Products being stocked</h3><p class="card-desc">Check back soon.</p></div>
