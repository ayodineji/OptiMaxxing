<!-- PRODUCTS -->
<section class="om-products">
  {% assign proto_ids   = 'facemaxx,sleepmaxx,gymmaxx,framemaxx,stylemaxx,mindmaxx,cleanmaxx' | split: ',' %}
  {% assign proto_nums  = '01,02,03,04,05,06' | split: ',' %}
  {% assign proto_names = 'Facemaxx,Sleepmaxx,Gymmaxx,Framemaxx,Stylemaxx,Mindmaxx,Cleanmaxx' | split: ',' %}

  {% for proto_id in proto_ids %}
    {% assign proto_num  = proto_nums[forloop.index0] %}
    {% assign proto_name = proto_names[forloop.index0] %}

    {% if proto_id == 'facemaxx'  %}
      {% assign col = col_facemaxx %}
      {% assign proto_desc = 'Your face is a variable. These are the clinical-grade tools to adjust it. LED therapy, microcurrent, cryotherapy — delivered to your door.' %}
    {% endif %}
    {% if proto_id == 'sleepmaxx' %}
      {% assign col = col_sleepmaxx %}
      {% assign proto_desc = 'Sleep is when testosterone is produced. When your face decompresses. When your brain consolidates. Unoptimized sleep destroys everything downstream.' %}
    {% endif %}
    {% if proto_id == 'gymmaxx'   %}
      {% assign col = col_gymmaxx %}
      {% assign proto_desc = 'Training is only half the protocol. Recovery, mobility, and output optimization are where serious gains are made.' %}
    {% endif %}
    {% if proto_id == 'framemaxx' %}
      {% assign col = col_framemaxx %}
      {% assign proto_desc = 'Your frame is the first thing people see before you say a word. Posture, shoulder width, spine alignment — these tools fix what sitting destroys.' %}
    {% endif %}
    {% if proto_id == 'stylemaxx' %}
      {% assign col = col_stylemaxx %}
      {% assign proto_desc = 'Your physical optimization is undermined by a wrinkled shirt. Clean shoes, groomed beard, pressed clothes — the finishing variables most men ignore.' %}
    {% endif %}
    {% if proto_id == 'mindmaxx'  %}
      {% assign col = col_mindmaxx %}
      {% assign proto_desc = 'The body is one variable. Your focus, output, and cognitive environment are equally optimizable. Tools for the desk and the mind.' %}
    {% endif %}
    {% if proto_id == 'cleanmaxx' %}
      {% assign col = col_cleanmaxx %}
      {% assign proto_desc = 'Most men optimize what they add to their lives. Cleanmaxx addresses what you eliminate. Toxins, endocrine disruptors, and chemical exposure are silent variables quietly working against every other protocol you run.' %}
    {% endif %}

    <div class="proto-panel{% if forloop.first %} active{% endif %}" id="{{ proto_id }}">
      <span class="section-tag">// Protocol {{ proto_num }}</span>
      <h2 class="section-heading">{{ proto_name | upcase }}</h2>
      <p class="section-body">{{ proto_desc }}</p>
      <a href="{{ col.url }}" class="view-all-link">View Full {{ proto_name }} Collection &rarr;</a>

      {% if col.products.size > 0 %}
        <div class="product-grid">
          {% for product in col.products limit: 4 %}
            <div class="product-card{% if forloop.first %} hero-card{% endif %}">
              {% if forloop.first %}<span class="card-badge">&#9733; Hero Product</span>
              {% else %}<span class="card-badge">Protocol Tool</span>{% endif %}

              {% if product.featured_image %}
                <img class="card-img"
                  src="{{ product.featured_image | image_url: width: 400 }}"
                  alt="{{ product.featured_image.alt | escape }}"
                  width="400" height="400" loading="lazy">
              {% else %}
                <div class="card-img-placeholder"><span>Image pending</span></div>
              {% endif %}

              <h3 class="card-name">{{ product.title }}</h3>
              {% if product.metafields.custom.short_description != blank %}
                <p class="card-desc">{{ product.metafields.custom.short_description }}</p>
              {% elsif product.description != blank %}
                <p class="card-desc">{{ product.description | strip_html | truncate: 110 }}</p>
              {% endif %}
              <p class="card-price">
                {% if product.price_varies %}From {{ product.price_min | money }}
                {% else %}{{ product.price | money }}{% endif %}
              </p>
              <a href="{{ product.url }}" class="card-link">View Product</a>
            </div>
          {% endfor %}
        </div>
      {% else %}
        <div class="empty-col"><p>Products coming soon.</p></div>
      {% endif %}
    </div>
  {% endfor %}
</section>

