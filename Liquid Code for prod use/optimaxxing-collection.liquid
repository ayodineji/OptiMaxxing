{% comment %}
  OPTIMAXXING — Collection Page Section
  File: Sections/optimaxxing-collection.liquid

  Uses shared header via collection.json template.
  No <html>/<head>/<body> tags — Dawn's theme.liquid provides those.
{% endcomment %}

{% assign col = collection %}

{% comment %} Map collection handle to protocol number {% endcomment %}
{% assign proto_num = '' %}
{% assign proto_label = '' %}
{% if col.handle == 'facemaxx-protocol'  %}{% assign proto_num = '01' %}{% assign proto_label = 'Face Optimization' %}{% endif %}
{% if col.handle == 'sleepmaxx-protocol' %}{% assign proto_num = '02' %}{% assign proto_label = 'Sleep Optimization' %}{% endif %}
{% if col.handle == 'gymmaxx-protocol'   %}{% assign proto_num = '03' %}{% assign proto_label = 'Training & Recovery' %}{% endif %}
{% if col.handle == 'framemaxx-protocol' %}{% assign proto_num = '04' %}{% assign proto_label = 'Frame & Posture' %}{% endif %}
{% if col.handle == 'stylemaxx-protocol' %}{% assign proto_num = '05' %}{% assign proto_label = 'Style & Grooming' %}{% endif %}
{% if col.handle == 'mindmaxx-protocol'  %}{% assign proto_num = '06' %}{% assign proto_label = 'Focus & Cognition' %}{% endif %}
{% if col.handle == 'cleanmaxx-protocol' %}{% assign proto_num = '07' %}{% assign proto_label = 'Clean Living' %}{% endif %}

<style>
  /* COLLECTION HEADER */
  .col-header{padding:120px 48px 64px;border-bottom:1px solid var(--border);position:relative;overflow:hidden;}
  .col-header::before{content:'';position:absolute;top:-150px;right:-150px;width:500px;height:500px;background:radial-gradient(circle,rgba(200,255,0,0.05) 0%,transparent 65%);pointer-events:none;}
  .col-protocol-tag{font-family:'Space Mono',monospace;font-size:10px;letter-spacing:4px;color:var(--neon) !important;text-transform:uppercase;margin-bottom:12px;display:block;}
  .col-title{font-family:'Bebas Neue',sans-serif;font-size:clamp(56px,9vw,120px);line-height:0.9;color:var(--white) !important;margin-bottom:20px;}
  .col-desc{font-size:15px;color:var(--dim) !important;max-width:560px;line-height:1.85;margin-bottom:24px;}
  .col-meta{display:flex;gap:32px;flex-wrap:wrap;}
  .col-count{font-family:'Space Mono',monospace;font-size:10px;letter-spacing:2px;text-transform:uppercase;color:var(--dim) !important;}
  .col-count span{color:var(--neon) !important;font-weight:700;}

  /* SORT BAR */
  .col-sort-bar{display:flex;align-items:center;gap:12px;padding:16px 48px;background:var(--gray);border-bottom:1px solid var(--border);}
  .sort-label{font-family:'Space Mono',monospace;font-size:9px;letter-spacing:2px;text-transform:uppercase;color:var(--dim) !important;}
  .sort-select{font-family:'Space Mono',monospace;font-size:10px;letter-spacing:1px;background:var(--mid);color:var(--white) !important;border:1px solid var(--border);padding:8px 12px;cursor:pointer;}

  /* PRODUCT GRID */
  .col-main{padding:48px;}
  .col-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:2px;}

  /* PRODUCT CARDS */
  .product-card{background:var(--gray);padding:28px 24px;display:flex;flex-direction:column;transition:background 0.2s;}
  .product-card:hover{background:var(--mid);}
  .product-card.hero-card{background:var(--neon) !important;}
  .product-card.hero-card .card-badge{background:var(--black);color:var(--neon) !important;}
  .product-card.hero-card .card-name{color:var(--black) !important;}
  .product-card.hero-card .card-desc{color:rgba(0,0,0,0.5) !important;}
  .product-card.hero-card .card-price{color:var(--black) !important;}
  .product-card.hero-card .card-link{background:var(--black);color:var(--neon) !important;border-color:var(--black);}
  .card-badge{display:inline-block;margin-bottom:16px;font-family:'Space Mono',monospace;font-size:8px;letter-spacing:2px;text-transform:uppercase;padding:4px 10px;background:rgba(200,255,0,0.1);color:var(--neon) !important;}
  .card-img{width:100%;aspect-ratio:1;object-fit:cover;margin-bottom:20px;background:var(--mid);}
  .card-img-placeholder{width:100%;aspect-ratio:1;background:var(--mid);display:flex;align-items:center;justify-content:center;margin-bottom:20px;}
  .card-img-placeholder span{font-family:'Space Mono',monospace;font-size:10px;color:var(--dim) !important;letter-spacing:2px;text-transform:uppercase;}
  .card-name{font-family:'Bebas Neue',sans-serif;font-size:24px;color:var(--white) !important;line-height:1.1;margin-bottom:8px;}
  .card-desc{font-size:13px;color:var(--dim) !important;line-height:1.7;margin-bottom:16px;flex:1;}
  .card-price{font-family:'Space Mono',monospace;font-size:16px;font-weight:700;color:var(--neon) !important;margin-bottom:16px;}
  .card-compare{font-family:'Space Mono',monospace;font-size:12px;color:var(--dim) !important;text-decoration:line-through;margin-left:8px;}
  .card-link{display:block;width:100%;padding:12px;background:transparent;border:1px solid var(--border);font-family:'Space Mono',monospace;font-size:10px;font-weight:700;letter-spacing:2px;text-transform:uppercase;text-align:center;color:var(--white) !important;transition:all 0.2s;text-decoration:none !important;}
  .card-link:hover{background:var(--neon);border-color:var(--neon);color:var(--black) !important;}

  /* EMPTY STATE */
  .col-empty{padding:120px 48px;text-align:center;}
  .col-empty h2{font-family:'Bebas Neue',sans-serif;font-size:64px;color:var(--white) !important;margin-bottom:16px;}
  .col-empty p{font-size:15px;color:var(--dim) !important;margin-bottom:32px;}

  /* PAGINATION */
  .col-pagination{display:flex;justify-content:center;gap:6px;padding:48px;}
  .page-link{font-family:'Space Mono',monospace;font-size:11px;padding:8px 14px;background:var(--gray);color:var(--dim) !important;border:1px solid var(--border);text-decoration:none !important;transition:all 0.15s;}
  .page-link:hover{border-color:var(--neon);color:var(--neon) !important;}
  .page-link.active{background:var(--neon);color:var(--black) !important;border-color:var(--neon);}
  .page-link.disabled{opacity:0.3;pointer-events:none;}

  /* OTHER PROTOCOLS */
  .other-protocols{padding:48px;border-top:1px solid var(--border);}
  .other-heading{font-family:'Space Mono',monospace;font-size:10px;letter-spacing:3px;text-transform:uppercase;color:var(--dim) !important;margin-bottom:16px;}
  .proto-pills{display:flex;gap:8px;flex-wrap:wrap;}
  .proto-pill{font-family:'Space Mono',monospace;font-size:10px;letter-spacing:1px;text-transform:uppercase;padding:10px 18px;background:var(--gray);color:var(--dim) !important;border:1px solid var(--border);transition:all 0.15s;text-decoration:none !important;}
  .proto-pill:hover{border-color:var(--neon);color:var(--neon) !important;}
  .proto-pill.current{background:var(--neon);color:var(--black) !important;border-color:var(--neon);pointer-events:none;}

  @media(max-width:768px){
    .col-header{padding:100px 20px 48px;}
    .col-sort-bar{padding:12px 20px;}
    .col-main{padding:20px;}
    .col-grid{grid-template-columns:1fr;}
    .other-protocols{padding:32px 20px;}
  }
</style>

<!-- COLLECTION HEADER -->
<div class="col-header">
  {% if proto_num != '' %}
    <span class="col-protocol-tag">// Protocol {{ proto_num }} &nbsp;&middot;&nbsp; {{ proto_label }}</span>
  {% endif %}
  <h1 class="col-title">{{ col.title | upcase }}</h1>
  {% if col.description != blank %}
    <p class="col-desc">{{ col.description | strip_html }}</p>
  {% endif %}
  <div class="col-meta">
    <span class="col-count"><span>{{ col.products_count }}</span> tools in this protocol</span>
  </div>
</div>

<!-- SORT BAR -->
<div class="col-sort-bar">
  <div class="sort-label">Sort</div>
  <select class="sort-select" onchange="window.location=this.value">
    <option value="?sort_by=manual"{% if collection.sort_by == 'manual' %} selected{% endif %}>Featured</option>
    <option value="?sort_by=price-ascending"{% if collection.sort_by == 'price-ascending' %} selected{% endif %}>Price: Low to High</option>
    <option value="?sort_by=price-descending"{% if collection.sort_by == 'price-descending' %} selected{% endif %}>Price: High to Low</option>
    <option value="?sort_by=created-descending"{% if collection.sort_by == 'created-descending' %} selected{% endif %}>Newest</option>
    <option value="?sort_by=best-selling"{% if collection.sort_by == 'best-selling' %} selected{% endif %}>Best Selling</option>
  </select>
</div>

<!-- PRODUCTS -->
{% paginate col.products by 12 %}
  {% if col.products.size > 0 %}
    <div class="col-main">
      <div class="col-grid">
        {% for product in col.products %}
          <div class="product-card{% if forloop.first %} hero-card{% endif %}">
            {% if forloop.first %}
              <span class="card-badge">&#9733; Hero Product</span>
            {% else %}
              <span class="card-badge">Protocol Tool</span>
            {% endif %}

            {% if product.featured_image %}
              <img class="card-img" src="{{ product.featured_image | image_url: width: 600 }}" alt="{{ product.featured_image.alt | escape }}" width="600" height="600" loading="lazy">
            {% else %}
              <div class="card-img-placeholder"><span>Image pending</span></div>
            {% endif %}

            <h2 class="card-name">{{ product.title }}</h2>

            {% if product.metafields.custom.short_description != blank %}
              <p class="card-desc">{{ product.metafields.custom.short_description }}</p>
            {% elsif product.description != blank %}
              <p class="card-desc">{{ product.description | strip_html | truncate: 110 }}</p>
            {% endif %}

            <div style="display:flex;align-items:baseline;gap:4px;">
              <p class="card-price">
                {% if product.price_varies %}From {{ product.price_min | money }}
                {% else %}{{ product.price | money }}{% endif %}
              </p>
              {% if product.compare_at_price > product.price %}
                <span class="card-compare">{{ product.compare_at_price | money }}</span>
              {% endif %}
            </div>
            <a href="{{ product.url }}" class="card-link">View Product</a>
          </div>
        {% endfor %}
      </div>
    </div>

    {% if paginate.pages > 1 %}
      <div class="col-pagination">
        {% if paginate.previous %}
          <a class="page-link" href="{{ paginate.previous.url }}">&larr;</a>
        {% else %}
          <span class="page-link disabled">&larr;</span>
        {% endif %}
        {% for part in paginate.parts %}
          {% if part.is_link %}
            <a class="page-link" href="{{ part.url }}">{{ part.title }}</a>
          {% else %}
            {% if part.title == paginate.current_page %}
              <span class="page-link active">{{ part.title }}</span>
            {% else %}
              <span class="page-link">{{ part.title }}</span>
            {% endif %}
          {% endif %}
        {% endfor %}
        {% if paginate.next %}
          <a class="page-link" href="{{ paginate.next.url }}">&rarr;</a>
        {% else %}
          <span class="page-link disabled">&rarr;</span>
        {% endif %}
      </div>
    {% endif %}

  {% else %}
    <div class="col-empty">
      <h2>COMING SOON</h2>
      <p>This protocol is being stocked. Check back shortly.</p>
      <a href="{{ routes.root_url }}" class="card-link" style="display:inline-block;width:auto;padding:14px 40px;">&larr; Back to All Protocols</a>
    </div>
  {% endif %}
{% endpaginate %}

<!-- OTHER PROTOCOLS -->
<div class="other-protocols">
  <p class="other-heading">Other Protocols</p>
  <div class="proto-pills">
    <a href="{{ routes.collections_url }}/facemaxx-protocol" class="proto-pill{% if col.handle == 'facemaxx-protocol' %} current{% endif %}">01 Facemaxx</a>
    <a href="{{ routes.collections_url }}/sleepmaxx-protocol" class="proto-pill{% if col.handle == 'sleepmaxx-protocol' %} current{% endif %}">02 Sleepmaxx</a>
    <a href="{{ routes.collections_url }}/gymmaxx-protocol" class="proto-pill{% if col.handle == 'gymmaxx-protocol' %} current{% endif %}">03 Gymmaxx</a>
    <a href="{{ routes.collections_url }}/framemaxx-protocol" class="proto-pill{% if col.handle == 'framemaxx-protocol' %} current{% endif %}">04 Framemaxx</a>
    <a href="{{ routes.collections_url }}/stylemaxx-protocol" class="proto-pill{% if col.handle == 'stylemaxx-protocol' %} current{% endif %}">05 Stylemaxx</a>
    <a href="{{ routes.collections_url }}/mindmaxx-protocol" class="proto-pill{% if col.handle == 'mindmaxx-protocol' %} current{% endif %}">06 Mindmaxx</a>
    <a href="{{ routes.collections_url }}/cleanmaxx-protocol" class="proto-pill{% if col.handle == 'cleanmaxx-protocol' %} current{% endif %}" style="{% if col.handle == 'cleanmaxx-protocol' %}background:#00CFFF;color:var(--black){% else %}color:#00CFFF;border-color:#00CFFF22{% endif %}">07 Cleanmaxx</a>
  </div>
</div>

{% schema %}
{
  "name": "Optimaxxing Collection",
  "settings": [],
  "presets": [{ "name": "Optimaxxing Collection" }]
}
{% endschema %}
