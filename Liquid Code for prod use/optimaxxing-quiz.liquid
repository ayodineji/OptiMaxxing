<style>
  .section-header, header-drawer, .header-wrapper, .header, #shopify-section-header, .announcement-bar { display: none !important; }
  :root {
    --black: #050505;
    --neon:  #C8FF00;
    --white: #F5F5F5;
    --gray:  #111111;
    --mid:   #1a1a1a;
    --dim:   #555;
    --border:#1e1e1e;
  }
  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
  body { background: var(--black); color: var(--white); font-family: 'DM Sans', sans-serif; overflow-x: hidden; min-height: 100vh; cursor: pointer; }


  /* NAV */
  .nav { position: fixed; top: 0; left: 0; right: 0; z-index: 100; display: flex; justify-content: space-between; align-items: center; padding: 0 40px; height: 60px; background: rgba(5,5,5,0.96); backdrop-filter: blur(20px); border-bottom: 1px solid var(--border); }
  .nav-logo { font-family: 'Bebas Neue', sans-serif; font-size: 20px; letter-spacing: 4px; color: var(--neon); text-decoration: none; }
  .nav-logo span { color: var(--white); }
  .nav-back { font-family: 'Space Mono', monospace; font-size: 9px; letter-spacing: 2px; text-transform: uppercase; color: var(--dim); text-decoration: none; display: flex; align-items: center; gap: 8px; transition: color 0.2s; }
  .nav-back:hover { color: var(--white); }
  .nav-back::before { content: '←'; }

  /* QUIZ SHELL */
  .quiz-shell {
    min-height: 100vh; display: flex; flex-direction: column;
    padding-top: 60px;
  }

  /* PROGRESS */
  .progress-bar-track { height: 2px; background: var(--border); position: fixed; top: 60px; left: 0; right: 0; z-index: 99; }
  .progress-bar-fill { height: 100%; background: var(--neon); transition: width 0.5s cubic-bezier(0.4,0,0.2,1); width: 0%; }
  .progress-label { position: fixed; top: 70px; right: 40px; font-family: 'Space Mono', monospace; font-size: 9px; letter-spacing: 2px; text-transform: uppercase; color: var(--dim); z-index: 99; }

  /* SCREENS */
  .screen { display: none; flex: 1; }
  .screen.active { display: flex; flex-direction: column; }

  /* INTRO SCREEN */
  .intro {
    flex: 1; display: flex; flex-direction: column; justify-content: center;
    align-items: flex-start; padding: 80px 15vw; position: relative; overflow: hidden;
  }
  .intro-bg {
    position: absolute; inset: 0; pointer-events: none;
    background: radial-gradient(ellipse 60% 60% at 80% 50%, rgba(200,255,0,0.04) 0%, transparent 70%);
  }
  .intro-eyebrow { font-family: 'Space Mono', monospace; font-size: 10px; letter-spacing: 5px; text-transform: uppercase; color: var(--neon); margin-bottom: 24px; }
  .intro-title { font-family: 'Bebas Neue', sans-serif; font-size: clamp(64px, 10vw, 130px); line-height: 0.88; color: var(--white); margin-bottom: 32px; }
  .intro-title em { color: var(--neon); font-style: normal; display: block; }
  .intro-sub { font-size: 16px; color: var(--dim); line-height: 1.9; max-width: 480px; margin-bottom: 48px; }
  .intro-meta { font-family: 'Space Mono', monospace; font-size: 9px; letter-spacing: 2px; text-transform: uppercase; color: var(--dim); margin-bottom: 32px; display: flex; gap: 24px; }
  .intro-meta span { color: var(--neon); }
  .btn-start { background: var(--neon); color: var(--black); padding: 18px 48px; font-family: 'Space Mono', monospace; font-size: 12px; font-weight: 700; letter-spacing: 3px; text-transform: uppercase; border: none; cursor: pointer; display: inline-block; transition: opacity 0.2s; }
  .btn-start:hover { opacity: 0.88; }

  /* QUESTION SCREEN */
  .question-screen {
    flex: 1; display: flex; flex-direction: column; justify-content: center;
    padding: 80px 15vw; min-height: calc(100vh - 60px);
    animation: slideIn 0.4s ease;
  }
  @keyframes slideIn { from { opacity: 0; transform: translateY(16px); } to { opacity: 1; transform: translateY(0); } }

  .q-eyebrow { font-family: 'Space Mono', monospace; font-size: 9px; letter-spacing: 4px; text-transform: uppercase; color: var(--neon); margin-bottom: 20px; }
  .q-text { font-family: 'Bebas Neue', sans-serif; font-size: clamp(36px, 5vw, 68px); color: var(--white); line-height: 1.05; margin-bottom: 12px; }
  .q-sub { font-size: 14px; color: var(--dim); line-height: 1.8; margin-bottom: 48px; max-width: 500px; }

  .options { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; max-width: 720px; }
  .option {
    background: var(--gray); border: 1px solid var(--border);
    padding: 22px 24px; cursor: pointer; text-align: left;
    transition: all 0.18s ease; position: relative; overflow: hidden;
  }
  .option::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px; background: transparent; transition: background 0.2s; }
  .option:hover { background: var(--mid); border-color: #333; }
  .option:hover::before { background: var(--neon); }
  .option.selected { background: var(--mid); border-color: var(--neon); }
  .option.selected::before { background: var(--neon); }
  .option-letter { font-family: 'Space Mono', monospace; font-size: 9px; letter-spacing: 2px; text-transform: uppercase; color: var(--neon); margin-bottom: 10px; display: block; opacity: 0.6; }
  .option-text { font-size: 15px; color: var(--white); line-height: 1.5; font-weight: 500; }
  .option-sub { font-size: 12px; color: var(--dim); margin-top: 6px; line-height: 1.5; }

  .q-nav { display: flex; align-items: center; gap: 20px; margin-top: 48px; }
  .btn-next { background: var(--neon); color: var(--black); padding: 14px 36px; font-family: 'Space Mono', monospace; font-size: 10px; font-weight: 700; letter-spacing: 3px; text-transform: uppercase; border: none; cursor: pointer; opacity: 0.35; pointer-events: none; transition: opacity 0.2s; }
  .btn-next.ready { opacity: 1; pointer-events: all; }
  .btn-next.ready:hover { opacity: 0.88; }
  .btn-back-q { background: transparent; border: 1px solid var(--border); color: var(--dim); padding: 14px 24px; font-family: 'Space Mono', monospace; font-size: 10px; letter-spacing: 2px; text-transform: uppercase; cursor: pointer; transition: all 0.2s; }
  .btn-back-q:hover { border-color: var(--dim); color: var(--white); }

  /* RESULT SCREEN */
  .result-screen {
    flex: 1; padding: 80px 15vw; animation: slideIn 0.5s ease;
  }
  .result-eyebrow { font-family: 'Space Mono', monospace; font-size: 10px; letter-spacing: 5px; text-transform: uppercase; color: var(--neon); margin-bottom: 20px; }
  .result-title { font-family: 'Bebas Neue', sans-serif; font-size: clamp(56px, 8vw, 110px); line-height: 0.88; color: var(--white); margin-bottom: 32px; }
  .result-title em { color: var(--neon); font-style: normal; }
  .result-tagline { font-size: 16px; color: var(--dim); line-height: 1.9; max-width: 560px; margin-bottom: 64px; }

  .result-bundle {
    background: var(--gray); border-top: 2px solid var(--neon);
    padding: 40px; margin-bottom: 32px; max-width: 760px;
    position: relative;
  }
  .bundle-label { font-family: 'Space Mono', monospace; font-size: 9px; letter-spacing: 3px; text-transform: uppercase; color: var(--neon); margin-bottom: 12px; display: block; }
  .bundle-name { font-family: 'Bebas Neue', sans-serif; font-size: 48px; color: var(--white); line-height: 1; margin-bottom: 8px; }
  .bundle-why { font-size: 14px; color: var(--dim); line-height: 1.9; margin-bottom: 28px; max-width: 560px; }
  .bundle-items-label { font-family: 'Space Mono', monospace; font-size: 9px; letter-spacing: 3px; text-transform: uppercase; color: var(--dim); margin-bottom: 14px; }
  .bundle-items { display: flex; flex-direction: column; gap: 8px; margin-bottom: 32px; }
  .bundle-item { display: flex; align-items: center; gap: 10px; font-size: 14px; color: var(--white); }
  .bundle-item::before { content: ''; width: 4px; height: 4px; background: var(--neon); flex-shrink: 0; }
  .bundle-pricing { display: flex; align-items: flex-end; gap: 16px; margin-bottom: 28px; }
  .bundle-price { font-family: 'Bebas Neue', sans-serif; font-size: 64px; color: var(--neon); line-height: 1; }
  .bundle-was { font-family: 'Space Mono', monospace; font-size: 13px; color: var(--dim); text-decoration: line-through; padding-bottom: 10px; }
  .bundle-save { font-family: 'Space Mono', monospace; font-size: 10px; color: var(--dim); text-transform: uppercase; letter-spacing: 1px; padding-bottom: 12px; }
  .btn-add { display: block; background: var(--neon); color: var(--black); padding: 16px; font-family: 'Space Mono', monospace; font-size: 11px; font-weight: 700; letter-spacing: 3px; text-transform: uppercase; text-decoration: none; text-align: center; border: none; cursor: pointer; max-width: 340px; transition: opacity 0.2s; }
  .btn-add:hover { opacity: 0.88; }

  .result-also { margin-top: 48px; max-width: 760px; }
  .also-label { font-family: 'Space Mono', monospace; font-size: 9px; letter-spacing: 3px; text-transform: uppercase; color: var(--dim); margin-bottom: 20px; }
  .also-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2px; }
  .also-card { background: var(--gray); padding: 20px; border-top: 1px solid var(--border); transition: background 0.2s; text-decoration: none; display: block; }
  .also-card:hover { background: var(--mid); }
  .also-num { font-family: 'Space Mono', monospace; font-size: 9px; color: var(--neon); letter-spacing: 2px; margin-bottom: 6px; }
  .also-name { font-family: 'Bebas Neue', sans-serif; font-size: 22px; color: var(--white); margin-bottom: 4px; }
  .also-price { font-family: 'Space Mono', monospace; font-size: 11px; color: var(--dim); }

  .result-retake { margin-top: 40px; }
  .btn-retake { background: transparent; border: 1px solid var(--border); color: var(--dim); padding: 14px 28px; font-family: 'Space Mono', monospace; font-size: 10px; letter-spacing: 2px; text-transform: uppercase; cursor: pointer; transition: all 0.2s; }
  .btn-retake:hover { border-color: var(--dim); color: var(--white); }

  @media (max-width: 768px) {
    .nav { padding: 0 20px; }
    .progress-label { right: 20px; }
    .intro { padding: 60px 20px; }
    .question-screen { padding: 60px 20px; }
    .options { grid-template-columns: 1fr; }
    .result-screen { padding: 60px 20px; }
    .also-grid { grid-template-columns: 1fr; }
    body { cursor: auto; }
  }
</style>
</head>
