  function showScreen(id) {
    document.querySelectorAll('.screen').forEach(function(s) { s.classList.remove('active'); });
    document.getElementById('screen-' + id).classList.add('active');
  }

  function updateProgress() {
    var pct = currentQ === 0 ? 0 : (currentQ / questions.length) * 100;
    document.getElementById('progressFill').style.width = pct + '%';
    if (currentQ === 0) {
      document.getElementById('progressLabel').textContent = '';
    } else {
      document.getElementById('progressLabel').textContent = currentQ + ' / ' + questions.length;
    }
  }

  function renderQuestion(idx) {
    var q = questions[idx];
    var selected = answers[q.id] || null;
    var html = '<p class="q-eyebrow">' + q.eyebrow + '</p>';
    html += '<h2 class="q-text">' + q.text + '</h2>';
    html += '<p class="q-sub">' + q.sub + '</p>';
    html += '<div class="options">';
    q.options.forEach(function(opt) {
      var sel = selected === opt.value ? ' selected' : '';
      html += '<button class="option' + sel + '" onclick="selectOption(\'' + q.id + '\', \'' + opt.value + '\', this)">';
      html += '<span class="option-letter">— ' + opt.letter + '</span>';
      html += '<div class="option-text">' + opt.text + '</div>';
      html += '<div class="option-sub">' + opt.sub + '</div>';
      html += '</button>';
    });
    html += '</div>';
    html += '<div class="q-nav">';
    if (idx > 0) html += '<button class="btn-back-q" onclick="goBack()">← Back</button>';
    html += '<button class="btn-next' + (selected ? ' ready' : '') + '" id="btnNext" onclick="nextQuestion()">Continue →</button>';
    html += '</div>';
    var container = document.getElementById('questionContent');
    container.innerHTML = html;
    container.style.animation = 'none';
    container.offsetHeight; // reflow
    container.style.animation = '';
  }

  function selectOption(qid, value, el) {
    answers[qid] = value;
    document.querySelectorAll('.option').forEach(function(o) { o.classList.remove('selected'); });
    el.classList.add('selected');
    var btn = document.getElementById('btnNext');
    if (btn) { btn.classList.add('ready'); }
  }

  function nextQuestion() {
    var q = questions[currentQ];
    if (!answers[q.id]) return;
    currentQ++;
    updateProgress();
    if (currentQ >= questions.length) {
      showResult();
    } else {
      renderQuestion(currentQ);
    }
  }

  function goBack() {
    if (currentQ > 0) {
      currentQ--;
      updateProgress();
      renderQuestion(currentQ);
    }
  }

  function showResult() {
    document.getElementById('progressFill').style.width = '100%';
    document.getElementById('progressLabel').textContent = 'Complete';
    showScreen('result');
    var bundle = pickBundle();
    renderResult(bundle);
  }

  function pickBundle() {
    var p = answers.priority;
    var prob = answers.problem;
    var goal = answers.goal;
    var budget = answers.budget;
    var commit = answers.commitment;

    // Full stack override
    if (budget === 'full' || (budget === 'pro' && commit === 'high')) return bundles.full;

    // Sleep dominates if problem + priority align
    if (prob === 'sleep' || goal === 'sleep') return bundles.sleep;

    // Clean living
    if (prob === 'clean') return bundles.clean;

    // Face
    if (p === 'face' || goal === 'face') {
      if (budget === 'pro' || budget === 'mid') return bundles.face_mid;
      return bundles.face_entry;
    }

    // Gym/recovery
    if (p === 'gym') return bundles.gym;

    // Mind
    if (p === 'mind' || goal === 'mind') return bundles.mind;

    // Frame / style / presentation
    if (p === 'style' || prob === 'frame' || goal === 'frame') {
      if (p === 'style') return bundles.style;
      return bundles.frame;
    }

    // Default fallback
    return bundles.full;
  }

  function renderResult(b) {
    var html = '';
    html += '<p class="result-eyebrow">// Your Protocol Stack</p>';
    html += '<h2 class="result-title">YOUR BUNDLE<br>IS <em>' + (b.name.split(' ')[0]) + '.</em></h2>';
    html += '<p class="result-tagline">Based on your answers, this is the stack that addresses your highest-priority variable with the fastest compound results. Start here. Add to the system once it\'s running.</p>';
    html += '<div class="result-bundle">';
    html += '<span class="bundle-label">// ' + b.tag + '</span>';
    html += '<div class="bundle-name">' + b.name + '</div>';
    html += '<p class="bundle-why">' + b.why + '</p>';
    html += '<div class="bundle-items-label">What\'s included</div>';
    html += '<div class="bundle-items">';
    b.items.forEach(function(item) { html += '<div class="bundle-item">' + item + '</div>'; });
    html += '</div>';
    html += '<div class="bundle-pricing"><div class="bundle-price">' + b.price + '</div><div class="bundle-was">' + b.was + '</div><div class="bundle-save">' + b.save + '</div></div>';
    html += '<a href="{{ routes.root_url }}pages/bundles" class="btn-add">Add To Protocol →</a>';
    html += '</div>';

    if (b.related && b.related.length) {
      html += '<div class="result-also">';
      html += '<p class="also-label">// You may also want</p>';
      html += '<div class="also-grid">';
      b.related.forEach(function(r) {
        html += '<a href="{{ routes.root_url }}pages/bundles" class="also-card">';
        html += '<div class="also-num">' + r.num + '</div>';
        html += '<div class="also-name">' + r.name + '</div>';
        html += '<div class="also-price">' + r.price + '</div>';
        html += '</a>';
      });
      html += '</div></div>';
    }

    html += '<div class="result-retake"><button class="btn-retake" onclick="retake()">Retake Assessment</button></div>';
    document.getElementById('resultContent').innerHTML = html;
  }

  function retake() {
    currentQ = 0;
    answers = {};
    updateProgress();
    document.getElementById('progressLabel').textContent = '';
    document.getElementById('progressFill').style.width = '0%';
    showScreen('intro');
  }
</script>

{% schema %}
{
  "name": "Optimaxxing Quiz",
  "settings": [],
  "presets": [{ "name": "Optimaxxing Quiz" }]
}
{% endschema %}
