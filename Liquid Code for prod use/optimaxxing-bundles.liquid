{% comment %}
  OPTIMAXXING — Bundles Page Section
  File: Sections/optimaxxing-bundles.liquid

  HOW TO HOOK UP:
  1. Paste into Sections/optimaxxing-bundles.liquid
  2. Create Templates/page.bundles.json pointing to this section
  3. Create a Page in admin: handle "bundles", assign template "page.bundles"

  BUNDLE PRODUCTS:
  Create each bundle in the Shopify Bundles app, then reference by handle below.
  Update handles in the assign block if your product URLs differ.
{% endcomment %}

{% comment %} ── BUNDLE PRODUCT HANDLES ── {% endcomment %}
{% comment %} Update these handles to match your actual bundle product URLs {% endcomment %}
{% assign b01 = all_products['full-optimization-starter'] %}
{% assign b02 = all_products['facemaxx-starter-kit'] %}
{% assign b03 = all_products['facemaxx-pro-kit'] %}
{% assign b04 = all_products['sleepmaxx-night-protocol'] %}
{% assign b05 = all_products['gymmaxx-recovery-stack'] %}
{% assign b06 = all_products['framemaxx-daily-kit'] %}
{% assign b07 = all_products['stylemaxx-grooming-kit'] %}
{% assign b08 = all_products['mindmaxx-focus-protocol'] %}
{% assign b09 = all_products['cleanmaxx-clean-living-kit'] %}

<style>
  /* HERO */
  .hero{padding:140px 48px 80px;position:relative;overflow:hidden;border-bottom:1px solid var(--border);}
  .hero-bg{position:absolute;inset:0;pointer-events:none;background:radial-gradient(ellipse 60% 60% at 80% 50%,rgba(200,255,0,0.04) 0%,transparent 70%),repeating-linear-gradient(0deg,transparent,transparent 80px,rgba(255,255,255,0.012) 80px,rgba(255,255,255,0.012) 81px),repeating-linear-gradient(90deg,transparent,transparent 80px,rgba(255,255,255,0.012) 80px,rgba(255,255,255,0.012) 81px);}
  .hero-eyebrow{font-family:'Space Mono',monospace;font-size:10px;letter-spacing:5px;text-transform:uppercase;color:var(--neon) !important;margin-bottom:28px;opacity:0;animation:fadeUp 0.6s 0.1s forwards;}
  .hero-title{font-family:'Bebas Neue',sans-serif;font-size:clamp(64px,10vw,130px);line-height:0.88;color:var(--white) !important;max-width:900px;margin-bottom:40px;opacity:0;animation:fadeUp 0.7s 0.2s forwards;}
  .hero-title .line2{color:var(--neon) !important;}
  .hero-sub{font-size:17px;color:var(--dim) !important;line-height:2;max-width:580px;opacity:0;animation:fadeUp 0.7s 0.35s forwards;margin-bottom:48px;}
  .hero-stats{display:flex;gap:48px;flex-wrap:wrap;opacity:0;animation:fadeUp 0.6s 0.5s forwards;}
  .stat{display:flex;flex-direction:column;gap:4px;}
  .stat-n{font-family:'Bebas Neue',sans-serif;font-size:40px;color:var(--white) !important;line-height:1;}
  .stat-l{font-family:'Space Mono',monospace;font-size:9px;letter-spacing:2px;text-transform:uppercase;color:var(--dim) !important;}

  /* TICKER */
  .ticker{border-bottom:1px solid var(--border);overflow:hidden;white-space:nowrap;padding:12px 0;background:var(--neon);}
  .ticker-inner{display:inline-block;animation:tickerScroll 25s linear infinite;font-family:'Space Mono',monospace;font-size:10px;font-weight:700;letter-spacing:3px;text-transform:uppercase;color:var(--black) !important;}
  @keyframes tickerScroll{from{transform:translateX(0)}to{transform:translateX(-50%)}}

  /* FILTER BAR */
  .filter-bar{display:flex;align-items:center;gap:8px;padding:14px 48px;background:var(--gray);border-bottom:1px solid var(--border);overflow-x:auto;scrollbar-width:none;}
  .filter-bar::-webkit-scrollbar{display:none;}
  .filter-label{font-family:'Space Mono',monospace;font-size:9px;letter-spacing:2px;text-transform:uppercase;color:var(--dim) !important;margin-right:8px;flex-shrink:0;}
  .filter-btn{background:none;border:1px solid var(--border);cursor:pointer;font-family:'Space Mono',monospace;font-size:9px;letter-spacing:1.5px;text-transform:uppercase;color:var(--dim) !important;padding:7px 14px;white-space:nowrap;transition:all 0.2s;}
  .filter-btn:hover{border-color:var(--neon);color:var(--neon) !important;}
  .filter-btn.active{background:var(--neon);border-color:var(--neon);color:var(--black) !important;}

  /* BUNDLES */
  .bundles-section{padding:72px 48px;}
  .section-label{font-family:'Space Mono',monospace;font-size:10px;letter-spacing:4px;text-transform:uppercase;color:var(--neon) !important;display:block;margin-bottom:8px;}
  .section-title{font-family:'Bebas Neue',sans-serif;font-size:clamp(36px,5vw,64px);color:var(--white) !important;line-height:1;margin-bottom:48px;}
  .bundle-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(420px,1fr));gap:2px;}

  /* BUNDLE CARDS */
  .bundle-card{background:var(--gray);display:flex;flex-direction:column;overflow:hidden;transition:background 0.2s;}
  .bundle-card:hover{background:#161616;}
  .bundle-card.featured{grid-column:1 / -1;display:grid;grid-template-columns:1fr 1fr;}

  .card-visual{position:relative;background:var(--mid);padding:40px;display:flex;align-items:center;justify-content:center;min-height:280px;}
  .card-visual-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;max-width:200px;}
  .card-visual-item{width:80px;height:80px;border:1px solid var(--border);display:flex;align-items:center;justify-content:center;}
  .card-visual-item svg{width:32px;height:32px;stroke:var(--dim);}
  .card-visual-item.accent svg{stroke:var(--neon);}
  .proto-badge{position:absolute;top:16px;left:16px;font-family:'Space Mono',monospace;font-size:8px;letter-spacing:2px;text-transform:uppercase;color:var(--neon) !important;background:rgba(200,255,0,0.08);padding:4px 10px;}
  .save-badge{position:absolute;bottom:16px;right:16px;font-family:'Bebas Neue',sans-serif;font-size:32px;color:var(--neon) !important;line-height:1;}
  .save-badge span{display:block;font-family:'Space Mono',monospace;font-size:8px;letter-spacing:2px;text-transform:uppercase;color:var(--dim) !important;}

  .card-body{padding:32px;display:flex;flex-direction:column;flex:1;}
  .card-num{font-family:'Space Mono',monospace;font-size:9px;letter-spacing:2px;text-transform:uppercase;color:var(--dim) !important;margin-bottom:8px;}
  .card-name{font-family:'Bebas Neue',sans-serif;font-size:36px;color:var(--white) !important;line-height:1;margin-bottom:8px;}
  .bundle-card.featured .card-name{font-size:48px;}
  .card-tagline{font-family:'Space Mono',monospace;font-size:10px;letter-spacing:1px;color:var(--neon) !important;margin-bottom:16px;}
  .card-why{font-size:14px;color:var(--dim) !important;line-height:1.85;margin-bottom:24px;flex:1;}
  .bundle-card.featured .card-why{font-size:15px;max-width:480px;}
  .card-items{margin-bottom:24px;}
  .card-items-label{font-family:'Space Mono',monospace;font-size:9px;letter-spacing:3px;text-transform:uppercase;color:var(--dim) !important;margin-bottom:12px;padding-bottom:8px;border-bottom:1px solid var(--border);}
  .item-row{display:flex;align-items:center;gap:10px;padding:6px 0;border-bottom:1px solid var(--border);}
  .item-dot{width:4px;height:4px;background:var(--neon);flex-shrink:0;}
  .item-name{font-size:13px;color:var(--white) !important;flex:1;}
  .item-val{font-family:'Space Mono',monospace;font-size:10px;color:var(--dim) !important;text-decoration:line-through;}
  .card-pricing{display:flex;align-items:baseline;gap:12px;margin-bottom:20px;}
  .price-now{font-family:'Bebas Neue',sans-serif;font-size:48px;color:var(--neon) !important;line-height:1;}
  .bundle-card.featured .price-now{font-size:64px;}
  .price-was{font-family:'Space Mono',monospace;font-size:14px;color:var(--dim) !important;text-decoration:line-through;}
  .price-label{font-family:'Space Mono',monospace;font-size:10px;letter-spacing:1px;text-transform:uppercase;color:var(--neon) !important;background:rgba(200,255,0,0.1);padding:3px 8px;}
  .card-cta{display:block;width:100%;padding:16px;text-align:center;font-family:'Space Mono',monospace;font-size:11px;font-weight:700;letter-spacing:3px;text-transform:uppercase;border:1px solid var(--border);color:var(--white) !important;background:transparent;cursor:pointer;transition:all 0.2s;text-decoration:none !important;}
  .card-cta:hover{background:var(--neon);border-color:var(--neon);color:var(--black) !important;}
  .bundle-card.featured .card-cta{background:var(--neon);border-color:var(--neon);color:var(--black) !important;}
  .bundle-card.featured .card-cta:hover{opacity:0.85;}

  .reveal{opacity:0;transform:translateY(24px);transition:opacity 0.6s ease,transform 0.6s ease;}
  .reveal.visible{opacity:1;transform:translateY(0);}

  @keyframes fadeUp{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}

  @media(max-width:768px){
    .hero{padding:100px 20px 60px;}
    .hero-stats{gap:24px;}
    .filter-bar{padding:12px 20px;}
    .bundles-section{padding:48px 20px;}
    .bundle-grid{grid-template-columns:1fr;}
    .bundle-card.featured{grid-template-columns:1fr;}
    .card-visual{min-height:180px;padding:24px;}
    .card-body{padding:24px;}
  }
</style>

<!-- HERO -->
<section class="hero">
  <div class="hero-bg"></div>
  <p class="hero-eyebrow">// The Optimaxxing Stack</p>
  <h1 class="hero-title">
    SERIOUS MEN<br>
    <span class="line2">STACK TOOLS.</span>
  </h1>
  <p class="hero-sub">Individual tools optimize one variable. Protocol bundles optimize the system. Every bundle is built around a specific outcome — with the exact tools that compound into measurable results.</p>
  <div class="hero-stats">
    <div class="stat"><span class="stat-n">{{ section.settings.bundle_count | default: 9 }}</span><span class="stat-l">Protocol Bundles</span></div>
    <div class="stat"><span class="stat-n">30%</span><span class="stat-l">Average Savings</span></div>
    <div class="stat"><span class="stat-n">30</span><span class="stat-l">Day Guarantee</span></div>
